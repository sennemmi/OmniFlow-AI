# OmniFlowAI 环境变量配置模板
# 使用说明：
# 1. 复制此文件为 .env: cp .env.template .env
# 2. 修改 .env 文件中的配置值
# ============================================

# ============================================
# 应用基础配置
# ============================================

# 运行环境: development | production | testing
ENV=development

# 调试模式: true | false
# 生产环境必须设为 false
DEBUG=true

# 服务器监听地址
# 0.0.0.0 允许外部访问，127.0.0.1 仅本地访问
HOST=0.0.0.0

# 服务器端口
PORT=8000

# ============================================
# CORS 跨域配置
# ============================================

# 允许的跨域来源
# 生产环境应设置为具体域名，如: ["https://yourdomain.com"]
# 开发环境可设置为通配符: ["*"]
CORS_ORIGINS=["*"]

# ============================================
# 数据库配置
# ============================================

# SQLite 数据库 URL
# 使用 aiosqlite 驱动支持异步操作
# 路径相对于 backend 目录
DATABASE_URL=sqlite+aiosqlite:///./omniflowai.db

# ============================================
# AI 模型提供商配置
# ============================================

# LLM Provider 选择
# 可选值: openai | mimo | deepseek
LLM_PROVIDER=deepseek

# 默认模型名称
DEFAULT_MODEL=deepseek-chat

# --------------------------------------------
# OpenAI 配置
# --------------------------------------------
# OpenAI API 密钥
# 获取地址: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI API 基础地址
# 如需使用代理，可修改此项
OPENAI_API_BASE=https://api.openai.com/v1

# --------------------------------------------
# MiMo (小米米墨) 配置
# --------------------------------------------
# MiMo API 密钥
# 获取地址: https://platform.xiaomimimo.com
MIMO_API_KEY=your_mimo_api_key_here

# MiMo API 基础地址
MIMO_API_BASE=https://api.xiaomimimo.com/v1

# MiMo 默认模型
MIMO_DEFAULT_MODEL=mimo-v2.5-pro

# --------------------------------------------
# DeepSeek 配置（推荐）
# --------------------------------------------
# DeepSeek API 密钥
# 获取地址: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# DeepSeek API 基础地址
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# DeepSeek 模型选择
# 可选值:
#   - deepseek-chat: 普通对话模型（推荐，响应快）
#   - deepseek-reasoner: 推理模型（思考更深入，响应慢）
# 注意: reasoning 模型需要特殊处理 reasoning_content 字段
DEEPSEEK_DEFAULT_MODEL=deepseek-chat

# ============================================
# AI 目标项目配置
# ============================================

# AI 操作的目标项目绝对路径
# 这是 OmniFlowAI 将要分析和修改的项目目录
# 示例: /home/user/projects/my-project 或 C:/Users/user/projects/my-project
TARGET_PROJECT_PATH=/absolute/path/to/your/target/project

# ============================================
# GitHub 集成配置（可选，用于远程交付）
# ============================================

# GitHub Personal Access Token
# 用于创建 Pull Request，需要 repo 权限
# 获取地址: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# GitHub 仓库所有者（用户名或组织名）
GITHUB_OWNER=your_github_username

# GitHub 仓库名
GITHUB_REPO=your_repository_name

# ============================================
# 代码安全机制配置
# ============================================

# Read Token 密钥（用于验证先读后写机制）
# 如果不设置，系统会自动生成一个随机密钥（重启后失效）
# 生产环境建议设置固定值
READ_TOKEN_SECRET=

# ============================================
# 沙箱测试功能配置
# ============================================

# 沙箱测试功能开关
# true: 启用（默认）
# false: 禁用
SANDBOX_TEST_ENABLED=true

# ============================================
# Agent 执行超时配置
# ============================================

# Agent 执行总超时时间（秒）
AGENT_TIMEOUT=300

# Sandbox 代码执行超时时间（秒）
SANDBOX_EXEC_TIMEOUT=120

# LiteLLM API 调用超时时间（秒）
LITELLM_TIMEOUT=120

# ============================================
# 模型参数配置
# ============================================

# 模型最大输出 Token 数
# 增大此值可防止长输出被截断
LITELLM_MAX_TOKENS=65536
MAX_TOKENS=65536

# 模型温度参数 (0.0 - 2.0)
# 代码生成建议: 0.0 (确定性输出，防止随机性导致错误)
# 通用问答建议: 0.8
# 数学推理建议: 1.0
LLM_TEMPERATURE=0.0

# Top-P 采样参数 (0.0 - 1.0)
LLM_TOP_P=0.95

# ============================================
# Agent 调试配置
# ============================================

# 是否启用 Agent 调试输出
# true: 启用，会输出详细的 Agent 思考过程
# false: 禁用
AGENT_DEBUG_ENABLED=true

# Agent 调试输出目录
AGENT_DEBUG_OUTPUT_DIR=./agent_debug_output
