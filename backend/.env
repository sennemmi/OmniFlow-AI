# OmniFlowAI 环境变量配置
# ModelScope (魔搭) 模型供应商配置

# 应用配置
ENV=development
DEBUG=true

# 服务器配置
HOST=0.0.0.0
PORT=8000

# CORS 配置
CORS_ORIGINS=["*"]

# 数据库配置
DATABASE_URL=sqlite+aiosqlite:///./omniflowai.db

# ============================================
# 模型供应商配置
# ============================================

# 模型选择开关
# USE_MODELSCOPE=true  # 设置为 true 则使用 ModelScope，否则使用 OpenAI
USE_MODELSCOPE=true

# ModelScope (魔搭) 配置
MODELSCOPE_API_KEY=ms-18ff818a-003d-4b0a-82f0-5d8049eaceed
MODELSCOPE_API_BASE=https://api-inference.modelscope.cn/v1
# ModelScope 模型 ID，直接使用 Qwen/Qwen3.5-122B-A10B
DEFAULT_MODEL=Qwen/Qwen3.5-122B-A10B

# OpenAI 配置 (当 USE_MODELSCOPE=false 时使用)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1
