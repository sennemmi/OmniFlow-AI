AcceptText\":\"                    // 使用流式生成，逐token返回结果\\n                    // 注意：这里需要根据LangChain4j的API使用正确的流式生成方法\\n                    // 简化处理，模拟流式输出\",\"originTextLength\":134,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1774697109091},{\"originRange\":{\"start\":{\"line\":209,\"character\":0},\"end\":{\"line\":214,\"character\":21}},\"modifyRange\":{\"start\":{\"line\":209,\"character\":0},\"end\":{\"line\":214,\"character\":21}},\"action\":\"None\",\"isLine\":false,\"originText\":\"                    // 模拟流式输出，逐字符发送\\\\n                    for (int i = 0; i < answer.length(); i++) {\\\\n                        sink.next(String.valueOf(answer.charAt(i)));\\\\n                        // 模拟网络延迟\\\\n                        Thread.sleep(10);\\\\n                    }\",\"originAcceptText\":\"                    // 模拟流式输出，逐字符发送\\n                    for (int i = 0; i < answer.length(); i++) {\\n                        sink.next(String.valueOf(answer.charAt(i)));\\n                        // 模拟网络延迟\\n                        Thread.sleep(10);\\n                    }\",\"originTextLength\":266,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1774697109092}]",
  "range-cache-file:///c%3A/Users/xyx/Desktop/ai-playground-main/smart-home-rag/src/main/java/com/example/smarthome/service/DocumentProcessingService.java": "[{\"originRange\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":108,\"character\":0}},\"modifyRange\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":108,\"character\":0}},\"action\":\"None\",\"isLine\":false,\"originText\":\"package com.example.smarthome.service;\\\\n\\\\nimport dev.langchain4j.data.document.Document;\\\\nimport dev.langchain4j.data.document.splitter.DocumentSplitters;\\\\nimport dev.langchain4j.data.segment.TextSegment;\\\\nimport dev.langchain4j.model.embedding.EmbeddingModel;\\\\nimport dev.langchain4j.store.embedding.EmbeddingStore;\\\\nimport java.io.IOException;\\\\nimport java.nio.file.Files;\\\\nimport java.nio.file.Path;\\\\nimport java.util.List;\\\\nimport java.util.stream.Collectors;\\\\nimport org.slf4j.Logger;\\\\nimport org.slf4j.LoggerFactory;\\\\nimport org.springframework.beans.factory.annotation.Value;\\\\nimport org.springframework.core.io.Resource;\\\\nimport org.springframework.stereotype.Service;\\\\n\\\\n@Service\\\\npublic class DocumentProcessingService {\\\\n\\\\n    private static final Logger logger = LoggerFactory.getLogger(DocumentProcessingService.class);\\\\n\\\\n    private final EmbeddingModel embeddingModel;\\\\n    private final EmbeddingStore<TextSegment> embeddingStore;\\\\n    private final int chunkSize;\\\\n    private final int chunkOverlap;\\\\n\\\\n    public DocumentProcessingService(\\\\n            EmbeddingModel embeddingModel,\\\\n            EmbeddingStore<TextSegment> embeddingStore,\\\\n            @Value(\\\\\\\"${document.chunk.size}\\\\\\\") int chunkSize,\\\\n            @Value(\\\\\\\"${document.chunk.overlap}\\\\\\\") int chunkOverlap) {\\\\n        this.embeddingModel = embeddingModel;\\\\n        this.embeddingStore = embeddingStore;\\\\n        this.chunkSize = chunkSize;\\\\n        this.chunkOverlap = chunkOverlap;\\\\n    }\\\\n\\\\n    /**\\\\n     * 处理单个文档\\\\n     */\\\\n    public void processDocument(Resource resource, String deviceType, String deviceModel) throws IOException {\\\\n        logger.info(\\\\\\\"Processing document: {} for device {} {}\\\\\\\", resource.getFilename(), deviceType, deviceModel);\\\\n\\\\n        // 简化处理，直接创建文档\\\\n        String content = new String(resource.getInputStream().readAllBytes());\\\\n        Document document = Document.from(content);\\\\n\\\\n        // 分块 - 使用 Recursive Character 分块策略\\\\n        List<TextSegment> segments =\\\\n                DocumentSplitters.recursive(chunkSize, chunkOverlap).split(document);\\\\n\\\\n        logger.info(\\\\\\\"Split document into {} segments\\\\\\\", segments.size());\\\\n\\\\n        // 向量化并存储，添加设备类型和型号作为元数据\\\\n        for (TextSegment segment : segments) {\\\\n            // 创建带有元数据的新TextSegment\\\\n            TextSegment segmentWithMetadata = TextSegment.from(\\\\n                    segment.text(),\\\\n                    java.util.Map.of(\\\\n                            \\\\\\\"deviceType\\\\\\\", deviceType,\\\\n                            \\\\\\\"deviceModel\\\\\\\", deviceModel\\\\n                    )\\\\n            );\\\\n            embeddingStore.add(embeddingModel.embed(segmentWithMetadata.text()).content(), segmentWithMetadata);\\\\n        }\\\\n        logger.info(\\\\\\\"Document processed and stored successfully\\\\\\\");\\\\n    }\\\\n\\\\n    /**\\\\n     * 批量处理目录中的文档\\\\n     */\\\\n    public void processDocumentsInDirectory(Path directory) throws IOException {\\\\n        logger.info(\\\\\\\"Processing documents in directory: {}\\\\\\\", directory);\\\\n\\\\n        List<Path> files = Files.walk(directory)\\\\n                .filter(Files::isRegularFile)\\\\n                .filter(path -> {\\\\n                    String name = path.getFileName().toString().toLowerCase();\\\\n                    return name.endsWith(\\\\\\\".pdf\\\\\\\") || name.endsWith(\\\\\\\".docx\\\\\\\") || name.endsWith(\\\\\\\".txt\\\\\\\");\\\\n                })\\\\n                .collect(Collectors.toList());\\\\n\\\\n        logger.info(\\\\\\\"Found {} documents to process\\\\\\\", files.size());\\\\n\\\\n        for (Path file : files) {\\\\n            try {\\\\n                // 从文件名提取设备信息（示例逻辑）\\\\n                String fileName = file.getFileName().toString();\\\\n                String deviceType = extractDeviceType(fileName);\\\\n                String deviceModel = extractDeviceModel(fileName);\\\\n\\\\n                processDocument(\\\\n                        new org.springframework.core.io.FileSystemResource(file.toFile()), deviceType, deviceModel);\\\\n            } catch (Exception e) {\\\\n                logger.error(\\\\\\\"Error processing file: {}\\\\\\\", file, e);\\\\n            }\\\\n        }\\\\n    }\\\\n\\\\n    /**\\\\n     * 从文件名提取设备类型\\\\n     */\\\\n    private String extractDeviceType(String fileName) {\\\\n        // 简单示例逻辑，实际项目中可能需要更复杂的解析\\\\n        if (fileName.contains(\\\\\\\"ac\\\\\\\") || fileName.contains(\\\\\\\"air\\\\\\\")) {\\\\n            return \\\\\\\"air_conditioner\\\\\\\";\\\\n        } else if (fileName.contains(\\\\\\\"tv\\\\\\\") || fileName.contains(\\\\\\\"television\\\\\\\")) {\\\\n            return \\\\\\\"tv\\\\\\\";\\\\n        } else if (fileName.contains(\\\\\\\"refrigerator\\\\\\\") || fileName.contains(\\\\\\\"fridge\\\\\\\")) {\\\\n            return \\\\\\\"refrigerator\\\\\\\";\\\\n        } else {\\\\n            return \\\\\\\"other\\\\\\\";\\\\n        }\\\\n    }\\\\n\\\\n    /**\\\\n     * 从文件名提取设备型号\\\\n     */\\\\n    private String extractDeviceModel(String fileName) {\\\\n        // 简单示例逻辑，实际项目中可能需要更复杂的解析\\\\n        return fileName.split(\\\\\\\"\\\\\\\\\\\\\\\\.\\\\\\\")[0];\\\\n    }\\\\n}\\\\n\",\"originAcceptText\":\"package com.example.smarthome.service;\\n\\nimport dev.langchain4j.data.document.Document;\\nimport dev.langchain4j.data.document.splitter.DocumentSplitters;\\nimport dev.langchain4j.data.segment.TextSegment;\\nimport dev.langchain4j.model.embedding.EmbeddingModel;\\nimport dev.langchain4j.store.embedding.EmbeddingStore;\\nimport java.io.IOException;\\nimport java.nio.file.Files;\\nimport java.nio.file.Path;\\nimport java.util.List;\\nimport java.util.stream.Collectors;\\nimport org.slf4j.Logger;\\nimport org.slf4j.LoggerFactory;\\nimport org.springframework.beans.factory.annotation.Value;\\nimport org.springframework.core.io.Resource;\\nimport org.springframework.stereotype.Service;\\n\\n@Service\\npublic class DocumentProcessingService {\\n\\n    private static final Logger logger = LoggerFactory.getLogger(DocumentProcessingService.class);\\n\\n    private final EmbeddingModel embeddingModel;\\n    private final EmbeddingStore<TextSegment> embeddingStore;\\n    private final int chunkSize;\\n    private final int chunkOverlap;\\n\\n    public DocumentProcessingService(\\n            EmbeddingModel embeddingModel,\\n            EmbeddingStore<TextSegment> embeddingStore,\\n            @Value(\\\"${document.chunk.size}\\\") int chunkSize,\\n            @Value(\\\"${document.chunk.overlap}\\\") int chunkOverlap) {\\n        this.embeddingModel = embeddingModel;\\n        this.embeddingStore = embeddingStore;\\n        this.chunkSize = chunkSize;\\n        this.chunkOverlap = chunkOverlap;\\n    }\\n\\n    /**\\n     * 处理单个文档\\n     */\\n    public void processDocument(Resource resource, String deviceType, String deviceModel) throws IOException {\\n        logger.info(\\\"Processing document: {} for device {} {}\\\", resource.getFilename(), deviceType, deviceModel);\\n\\n        // 简化处理，直接创建文档\\n        String content = new String(resource.getInputStream().readAllBytes());\\n        Document document = Document.from(content);\\n\\n        // 分块 - 使用 Recursive Character 分块策略\\n        List<TextSegment> segments =\\n                DocumentSplitters.recursive(chunkSize, chunkOverlap).split(document);\\n\\n        logger.info(\\\"Split document into {} segments\\\", segments.size());\\n\\n        // 向量化并存储，添加设备类型和型号作为元数据\\n        for (TextSegment segment : segments) {\\n            // 创建带有元数据的新TextSegment\\n            TextSegment segmentWithMetadata = TextSegment.from(\\n                    segment.text(),\\n                    java.util.Map.of(\\n                            \\\"deviceType\\\", deviceType,\\n                            \\\"deviceModel\\\", deviceModel\\n                    )\\n            );\\n            embeddingStore.add(embeddingModel.embed(segmentWithMetadata.text()).content(), segmentWithMetadata);\\n        }\\n        logger.info(\\\"Document processed and stored successfully\\\");\\n    }\\n\\n    /**\\n     * 批量处理目录中的文档\\n     */\\n    public void processDocumentsInDirectory(Path directory) throws IOException {\\n        logger.info(\\\"Processing documents in directory: {}\\\", directory);\\n\\n        List<Path> files = Files.walk(directory)\\n                .filter(Files::isRegularFile)\\n                .filter(path -> {\\n                    String name = path.getFileName().toString().toLowerCase();\\n                    return name.endsWith(\\\".pdf\\\") || name.endsWith(\\\".docx\\\") || name.endsWith(\\\".txt\\\");\\n                })\\n                .collect(Collectors.toList());\\n\\n        logger.info(\\\"Found {} documents to process\\\", files.size());\\n\\n        for (Path file : files) {\\n            try {\\n                // 从文件名提取设备信息（示例逻辑）\\n                String fileName = file.getFileName().toString();\\n                String deviceType = extractDeviceType(fileName);\\n                String deviceModel = extractDeviceModel(fileName);\\n\\n                processDocument(\\n                        new org.springframework.core.io.FileSystemResource(file.toFile()), deviceType, deviceModel);\\n            } catch (Exception e) {\\n                logger.error(\\\"Error processing file: {}\\\", file, e);\\n            }\\n        }\\n    }\\n\\n    /**\\n     * 从文件名提取设备类型\\n     */\\n    private String extractDeviceType(String fileName) {\\n        // 简单示例逻辑，实际项目中可能需要更复杂的解析\\n        if (fileName.contains(\\\"ac\\\") || fileName.contains(\\\"air\\\")) {\\n            return \\\"air_conditioner\\\";\\n        } else if (fileName.contains(\\\"tv\\\") || fileName.contains(\\\"television\\\")) {\\n            return \\\"tv\\\";\\n        } else if (fileName.contains(\\\"refrigerator\\\") || fileName.contains(\\\"fridge\\\")) {\\n            return \\\"refrigerator\\\";\\n        } else {\\n            return \\\"other\\\";\\n        }\\n    }\\n\\n    /**\\n     * 从文件名提取设备型号\\n     */\\n    private String extractDeviceModel(String fileName) {\\n        // 简单示例逻辑，实际项目中可能需要更复杂的解析\\n        return fileName.split(\\\"\\\\\\\\.\\\")[0];\\n    }\\n}\\n\",\"originTextLength\":4584,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1774701279491},{\"originRange\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":107,\"character\":0}},\"modifyRange\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":107,\"character\":0}},\"action\":\"None\",\"isLine\":false,\"originText\":\"package com.example.smarthome.service;\\\\n\\\\nimport dev.langchain4j.data.document.Document;\\\\nimport dev.langchain4j.data.document.Metadata;\\\\nimport dev.langchain4j.data.document.splitter.DocumentSplitters;\\\\nimport dev.langchain4j.data.segment.TextSegment;\\\\nimport dev.langchain4j.model.embedding.EmbeddingModel;\\\\nimport dev.langchain4j.store.embedding.EmbeddingStore;\\\\nimport java.io.IOException;\\\\nimport java.nio.file.Files;\\\\nimport java.nio.file.Path;\\\\nimport java.util.List;\\\\nimport java.util.stream.Collectors;\\\\nimport org.slf4j.Logger;\\\\nimport org.slf4j.LoggerFactory;\\\\nimport org.springframework.beans.factory.annotation.Value;\\\\nimport org.springframework.core.io.Resource;\\\\nimport org.springframework.stereotype.Service;\\\\n\\\\n@Service\\\\npublic class DocumentProcessingService {\\\\n\\\\n    private static final Logger logger = LoggerFactory.getLogger(DocumentProcessingService.class);\\\\n\\\\n    private final EmbeddingModel embeddingModel;\\\\n    private final EmbeddingStore<TextSegment> embeddingStore;\\\\n    private final int chunkSize;\\\\n    private final int chunkOverlap;\\\\n\\\\n    public DocumentProcessingService(\\\\n            EmbeddingModel embeddingModel,\\\\n            EmbeddingStore<TextSegment> embeddingStore,\\\\n            @Value(\\\\\\\"${document.chunk.size}\\\\\\\") int chunkSize,\\\\n            @Value(\\\\\\\"${document.chunk.overlap}\\\\\\\") int chunkOverlap) {\\\\n        this.embeddingModel = embeddingModel;\\\\n        this.embeddingStore = embeddingStore;\\\\n        this.chunkSize = chunkSize;\\\\n        this.chunkOverlap = chunkOverlap;\\\\n    }\\\\n\\\\n    /**\\\\n     * 处理单个文档\\\\n     */\\\\n    public void processDocument(Resource resource, String deviceType, String deviceModel) throws IOException {\\\\n        logger.info(\\\\\\\"Processing document: {} for device {} {}\\\\\\\", resource.getFilename(), deviceType, deviceModel);\\\\n\\\\n        // 简化处理，直接创建文档\\\\n        String content = new String(resource.getInputStream().readAllBytes());\\\\n        Document document = Document.from(content);\\\\n\\\\n        // 分块 - 使用 Recursive Character 分块策略\\\\n        List<TextSegment> segments =\\\\n                DocumentSplitters.recursive(chunkSize, chunkOverlap).split(document);\\\\n\\\\n        logger.info(\\\\\\\"Split document into {} segments\\\\\\\", segments.size());\\\\n\\\\n        // 向量化并存储，添加设备类型和型号作为元数据\\\\n        for (TextSegment segment : segments) {\\\\n            // 创建带有元数据的新TextSegment\\\\n            Metadata metadata = Metadata.from(\\\\n                    \\\\\\\"deviceType\\\\\\\", deviceType,\\\\n                    \\\\\\\"deviceModel\\\\\\\", deviceModel\\\\n            );\\\\n            TextSegment segmentWithMetadata = TextSegment.from(segment.text(), metadata);\\\\n            embeddingStore.add(embeddingModel.embed(segmentWithMetadata.text()).content(), segmentWithMetadata);\\\\n        }\\\\n        logger.info(\\\\\\\"Document processed and stored successfully\\\\\\\");\\\\n    }\\\\n\\\\n    /**\\\\n     * 批量处理目录中的文档\\\\n     */\\\\n    public void processDocumentsInDirectory(Path directory) throws IOException {\\\\n        logger.info(\\\\\\\"Processing documents in directory: {}\\\\\\\", directory);\\\\n\\\\n        List<Path> files = Files.walk(directory)\\\\n                .filter(Files::isRegularFile)\\\\n                .filter(path -> {\\\\n                    String name = path.getFileName().toString().toLowerCase();\\\\n                    return name.endsWith(\\\\\\\".pdf\\\\\\\") || name.endsWith(\\\\\\\".docx\\\\\\\") || name.endsWith(\\\\\\\".txt\\\\\\\");\\\\n                })\\\\n                .collect(Collectors.toList());\\\\n\\\\n        logger.info(\\\\\\\"Found {} documents to process\\\\\\\", files.size());\\\\n\\\\n        for (Path file : files) {\\\\n            try {\\\\n                // 从文件名提取设备信息（示例逻辑）\\\\n                String fileName = file.getFileName().toString();\\\\n                String deviceType = extractDeviceType(fileName);\\\\n                String deviceModel = extractDeviceModel(fileName);\\\\n\\\\n                processDocument(\\\\n                        new org.springframework.core.io.FileSystemResource(file.toFile()), deviceType, deviceModel);\\\\n            } catch (Exception e) {\\\\n                logger.error(\\\\\\\"Error processing file: {}\\\\\\\", file, e);\\\\n            }\\\\n        }\\\\n    }\\\\n\\\\n    /**\\\\n     * 从文件名提取设备类型\\\\n     */\\\\n    private String extractDeviceType(String fileName) {\\\\n        // 简单示例逻辑，实际项目中可能需要更复杂的解析\\\\n        if (fileName.contains(\\\\\\\"ac\\\\\\\") || fileName.contains(\\\\\\\"air\\\\\\\")) {\\\\n            return \\\\\\\"air_conditioner\\\\\\\";\\\\n        } else if (fileName.contains(\\\\\\\"tv\\\\\\\") || fileName.contains(\\\\\\\"television\\\\\\\")) {\\\\n            return \\\\\\\"tv\\\\\\\";\\\\n        } else if (fileName.contains(\\\\\\\"refrigerator\\\\\\\") || fileName.contains(\\\\\\\"fridge\\\\\\\")) {\\\\n            return \\\\\\\"refrigerator\\\\\\\";\\\\n        } else {\\\\n            return \\\\\\\"other\\\\\\\";\\\\n        }\\\\n    }\\\\n\\\\n    /**\\\\n     * 从文件名提取设备型号\\\\n     */\\\\n    private String extractDeviceModel(String fileName) {\\\\n        // 简单示例逻辑，实际项目中可能需要更复杂的解析\\\\n        return fileName.split(\\\\\\\"\\\\\\\\\\\\\\\\.\\\\\\\")[0];\\\\n    }\\\\n}\\\\n\",\"originAcceptText\":\"package com.example.smarthome.service;\\n\\nimport dev.langchain4j.data.document.Document;\\nimport dev.langchain4j.data.document.Metadata;\\nimport dev.langchain4j.data.document.splitter.DocumentSplitters;\\nimport dev.langchain4j.data.segment.TextSegment;\\nimport dev.langchain4j.model.embedding.EmbeddingModel;\\nimport dev.langchain4j.store.embedding.EmbeddingStore;\\nimport java.io.IOException;\\nimport java.nio.file.Files;\\nimport java.nio.file.Path;\\nimport java.util.List;\\nimport java.util.stream.Collectors;\\nimport org.slf4j.Logger;\\nimport org.slf4j.LoggerFactory;\\nimport org.springframework.beans.factory.annotation.Value;\\nimport org.springframework.core.io.Resource;\\nimport org.springframework.stereotype.Service;\\n\\n@Service\\npublic class DocumentProcessingService {\\n\\n    private static final Logger logger = LoggerFactory.getLogger(DocumentProcessingService.class);\\n\\n    private final EmbeddingModel embeddingModel;\\n    private final EmbeddingStore<TextSegment> embeddingStore;\\n    private final int chunkSize;\\n    private final int chunkOverlap;\\n\\n    public DocumentProcessingService(\\n            EmbeddingModel embeddingModel,\\n            EmbeddingStore<TextSegment> embeddingStore,\\n            @Value(\\\"${document.chunk.size}\\\") int chunkSize,\\n            @Value(\\\"${document.chunk.overlap}\\\") int chunkOverlap) {\\n        this.embeddingModel = embeddingModel;\\n        this.embeddingStore = embeddingStore;\\n        this.chunkSize = chunkSize;\\n        this.chunkOverlap = chunkOverlap;\\n    }\\n\\n    /**\\n     * 处理单个文档\\n     */\\n    public void processDocument(Resource resource, String deviceType, String deviceModel) throws IOException {\\n        logger.info(\\\"Processing document: {} for device {} {}\\\", resource.getFilename(), deviceType, deviceModel);\\n\\n        // 简化处理，直接创建文档\\n        String content = new String(resource.getInputStream().readAllBytes());\\n        Document document = Document.from(content);\\n\\n        // 分块 - 使用 Recursive Character 分块策略\\n        List<TextSegment> segments =\\n                DocumentSplitters.recursive(chunkSize, chunkOverlap).split(document);\\n\\n        logger.info(\\\"Split document into {} segments\\\", segments.size());\\n\\n        // 向量化并存储，添加设备类型和型号作为元数据\\n        for (TextSegment segment : segments) {\\n            // 创建带有元数据的新TextSegment\\n            Metadata metadata = Metadata.from(\\n                    \\\"deviceType\\\", deviceType,\\n                    \\\"deviceModel\\\", deviceModel\\n            );\\n            TextSegment segmentWithMetadata = TextSegment.from(segment.text(), metadata);\\n            embeddingStore.add(embeddingModel.embed(segmentWithMetadata.text()).content(), segmentWithMetadata);\\n        }\\n        logger.info(\\\"Document processed and stored successfully\\\");\\n    }\\n\\n    /**\\n     * 批量处理目录中的文档\\n     */\\n    public void processDocumentsInDirectory(Path directory) throws IOException {\\n        logger.info(\\\"Processing documents in directory: {}\\\", directory);\\n\\n        List<Path> files = Files.walk(directory)\\n                .filter(Files::isRegularFile)\\n                .filter(path -> {\\n                    String name = path.getFileName().toString().toLowerCase();\\n                    return name.endsWith(\\\".pdf\\\") || name.endsWith(\\\".docx\\\") || name.endsWith(\\\".txt\\\");\\n                })\\n                .collect(Collectors.toList());\\n\\n        logger.info(\\\"Found {} documents to process\\\", files.size());\\n\\n        for (Path file : files) {\\n            try {\\n                // 从文件名提取设备信息（示例逻辑）\\n                String fileName = file.getFileName().toString();\\n                String deviceType = extractDeviceType(fileName);\\n                String deviceModel = extractDeviceModel(fileName);\\n\\n                processDocument(\\n                        new org.springframework.core.io.FileSystemResource(file.toFile()), deviceType, deviceModel);\\n            } catch (Exception e) {\\n                logger.error(\\\"Error processing file: {}\\\", file, e);\\n            }\\n        }\\n    }\\n\\n    /**\\n     * 从文件名提取设备类型\\n     */\\n    private String extractDeviceType(String fileName) {\\n        // 简单示例逻辑，实际项目中可能需要更复杂的解析\\n        if (fileName.contains(\\\"ac\\\") || fileName.contains(\\\"air\\\")) {\\n            return \\\"air_conditioner\\\";\\n        } else if (fileName.contains(\\\"tv\\\") || fileName.contains(\\\"television\\\")) {\\n            return \\\"tv\\\";\\n        } else if (fileName.contains(\\\"refrigerator\\\") || fileName.contains(\\\"fridge\\\")) {\\n            return \\\"refrigerator\\\";\\n        } else {\\n            return \\\"other\\\";\\n        }\\n    }\\n\\n    /**\\n     * 从文件名提取设备型号\\n     */\\n    private String extractDeviceModel(String fileName) {\\n        // 简单示例逻辑，实际项目中可能需要更复杂的解析\\n        return fileName.split(\\\"\\\\\\\\.\\\")[0];\\n    }\\n}\\n\",\"originTextLength\":4592,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1774701988706},{\"originRange\":{\"start\":{\"line\":59,\"character\":0},\"end\":{\"line\":62,\"character\":59}},\"modifyRange\":{\"start\":{\"line\":59,\"character\":0},\"end\":{\"line\":62,\"character\":59}},\"action\":\"None\",\"isLine\":false,\"originText\":\"            java.util.Map<String, String> metadataMap = new java.util.HashMap<>();\\\\n            metadataMap.put(\\\\\\\"deviceType\\\\\\\", deviceType);\\\\n            metadataMap.put(\\\\\\\"deviceModel\\\\\\\", deviceModel);\\\\n            Metadata metadata = Metadata.from(metadataMap);\",\"originAcceptText\":\"            java.util.Map<String, String> metadataMap = new java.util.HashMap<>();\\n            metadataMap.put(\\\"deviceType\\\", deviceType);\\n            metadataMap.put(\\\"deviceModel\\\", deviceModel);\\n            Metadata metadata = Metadata.from(metadataMap);\",\"originTextLength\":254,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1774702300506},{\"originRange\":{\"start\":{\"line\":59,\"character\":0},\"end\":{\"line\":62,\"character\":15}},\"modifyRange\":{\"start\":{\"line\":59,\"character\":0},\"end\":{\"line\":62,\"character\":15}},\"action\":\"None\",\"isLine\":false,\"originText\":\"            Metadata metadata = Metadata.from(java.util.Map.of(\\\\n                    \\\\\\\"deviceType\\\\\\\", deviceType,\\\\n                    \\\\\\\"deviceModel\\\\\\\", deviceModel\\\\n            ));\",\"originAcceptText\":\"            Metadata metadata = Metadata.from(java.util.Map.of(\\n                    \\\"deviceType\\\", deviceType,\\n                    \\\"deviceModel\\\", deviceModel\\n            ));\",\"originTextLength\":172,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1774702487528}]",
  "range-cache-file:///c%3A/Users/xyx/Desktop/ai-playground-main/smart-home-rag/README.md": "[{\"originRange\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":111,\"character\":0}},\"modifyRange\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":111,\"character\":0}},\"action\":\"None\",\"isLine\":false,\"originText\":\"# 基于 RAG 架构的智能家居知识库助手\\\\n\\\\n## 项目概述\\\\n\\\\n基于 LangChain4j 构建的 Java RAG 系统，旨在解决智能家居产品手册冗长、故障自检困难等痛点。通过全链路向量检索架构实现精准的功能引导，将海量非结构化说明书转化为交互式问答，显著提升了用户的售后自助服务体验。\\\\n\\\\n## 技术栈\\\\n\\\\n- Spring Boot 3.5.3\\\\n- LangChain4j 0.24.0\\\\n- Spring AI 1.0.0\\\\n- Milvus 2.3.4（向量数据库）\\\\n- Redis 7.2（会话管理）\\\\n- WebFlux（流式响应）\\\\n- Apache Tika（文档解析）\\\\n\\\\n## 核心功能\\\\n\\\\n1. **智能文档处理**：支持 PDF、DOCX、TXT 等格式的文档上传和处理\\\\n2. **Recursive Character 分块策略**：针对智能家居手册的排版特点优化了 Chunk Size 与 Overlap 参数\\\\n3. **多层级 System Prompt**：约束模型行为，引入 Few-Shot 引导模型识别复杂的故障排查意图\\\\n4. **Milvus 元数据过滤**：实现针对不同设备型号的物理隔离检索\\\\n5. **Server-Sent Events 流式响应**：为用户提供低延迟的打字机交互体验\\\\n6. **Redis 会话管理**：实现对话记忆管理，通过冗余消息裁剪节省 Token 消耗\\\\n\\\\n## 系统架构\\\\n\\\\n1. **数据层**：Milvus 向量数据库存储文档嵌入\\\\n2. **服务层**：\\\\n   - DocumentProcessingService：文档处理、分块、向量化\\\\n   - SmartHomeQueryService：RAG 核心逻辑\\\\n   - SessionManagementService：会话管理\\\\n3. **API 层**：RESTful API 和流式 API\\\\n4. **前端**：Swagger UI（测试）/ 前端应用（可选）\\\\n\\\\n## 快速开始\\\\n\\\\n### 1. 启动依赖服务\\\\n\\\\n使用 Docker Compose 启动 Milvus 和 Redis：\\\\n\\\\n```bash\\\\ncd docker\\\\ndocker-compose up -d\\\\n```\\\\n\\\\n### 2. 构建和运行应用\\\\n\\\\n```bash\\\\n# 构建应用\\\\n./mvnw clean package\\\\n\\\\n# 运行应用\\\\n./mvnw spring-boot:run\\\\n```\\\\n\\\\n### 3. 访问 Swagger UI\\\\n\\\\n应用启动后，访问：\\\\n- **Swagger UI**：http://localhost:8082/swagger-ui/index.html\\\\n\\\\n## API 端点\\\\n\\\\n| 端点 | 方法 | 功能 |\\\\n|------|------|------|\\\\n| `/api/smarthome/query` | POST | 智能家具查询 |\\\\n| `/api/smarthome/query/stream` | POST | 流式智能家具查询 |\\\\n| `/api/smarthome/documents` | POST | 上传和处理文档 |\\\\n| `/api/smarthome/session` | GET | 获取会话历史 |\\\\n| `/api/smarthome/session` | DELETE | 清除会话 |\\\\n\\\\n## 请求示例\\\\n\\\\n### 智能家具查询\\\\n\\\\n```json\\\\nPOST /api/smarthome/query\\\\nContent-Type: application/json\\\\n\\\\n{\\\\n  \\\\\\\"query\\\\\\\": \\\\\\\"我的空调不制冷了怎么办？\\\\\\\",\\\\n  \\\\\\\"deviceType\\\\\\\": \\\\\\\"air_conditioner\\\\\\\",\\\\n  \\\\\\\"deviceModel\\\\\\\": \\\\\\\"KFR-35GW\\\\\\\"\\\\n}\\\\n```\\\\n\\\\n### 上传文档\\\\n\\\\n```bash\\\\nPOST /api/smarthome/documents\\\\nContent-Type: multipart/form-data\\\\n\\\\n# 参数\\\\n- file: 文档文件（PDF、DOCX、TXT）\\\\n- deviceType: 设备类型（如 air_conditioner、tv、refrigerator）\\\\n- deviceModel: 设备型号\\\\n```\\\\n\\\\n## 性能优化\\\\n\\\\n1. **分块策略**：使用 Recursive Character 分块策略，Chunk Size 设为 1000，Overlap 设为 200\\\\n2. **向量检索**：使用 Milvus 向量数据库，Top-3 召回率达 84%\\\\n3. **Prompt 优化**：多层级 System Prompt + Few-Shot 引导，幻觉率从 23% 下降至 6%\\\\n4. **流式响应**：首 token 响应延迟控制在 280ms 以内\\\\n5. **会话管理**：Redis 滑动窗口实现对话记忆管理，平均 Token 用量从 3200 降至 1800\\\\n\\\\n## 目录结构\\\\n\\\\n```\\\\nsmart-home-rag/\\\\n├── docker/              # Docker 配置\\\\n│   └── docker-compose.yml\\\\n├── src/\\\\n│   ├── main/\\\\n│   │   ├── java/com/example/smarthome/\\\\n│   │   │   ├── config/     # 配置类\\\\n│   │   │   ├── controller/  # 控制器\\\\n│   │   │   ├── service/     # 服务\\\\n│   │   │   ├── domain/      # 领域模型\\\\n│   │   │   └── SmartHomeRagApplication.java\\\\n│   │   └── resources/       # 资源文件\\\\n│   └── test/                # 测试\\\\n├── pom.xml                  # Maven 配置\\\\n└── README.md                # 项目说明\\\\n```\\\\n\\\\n## 注意事项\\\\n\\\\n1. **Milvus 配置**：确保 Milvus 服务正常运行，默认端口为 19530\\\\n2. **Redis 配置**：确保 Redis 服务正常运行，默认端口为 6379\\\\n3. **OpenAI API**：项目使用 langchain4j 提供的免费演示 API，无需真实的 OpenAI API Key\\\\n4. **文档处理**：支持 PDF、DOCX、TXT 格式的文档，建议文档大小不超过 50MB\\\\n\\\\n## 故障排查\\\\n\\\\n1. **Milvus 连接失败**：检查 Docker 容器是否正常运行，端口是否正确\\\\n2. **Redis 连接失败**：检查 Redis 容器是否正常运行，端口是否正确\\\\n3. **文档处理失败**：检查文档格式是否支持，文件大小是否超限\\\\n4. **查询响应慢**：检查网络连接，考虑优化文档分块策略\\\\n\\\\n## 未来规划\\\\n\\\\n1. **多语言支持**：添加多语言文档处理和响应能力\\\\n2. **多模态支持**：支持图片、视频等多模态内容\\\\n3. **个性化推荐**：基于用户历史查询提供个性化推荐\\\\n4. **模型微调**：使用领域数据对模型进行微调，提升专业度\\\\n5. **前端应用**：开发专门的前端应用，提供更好的用户体验\\\\n\",\"originAcceptText\":\"# 基于 RAG 架构的智能家居知识库助手\\n\\n## 项目概述\\n\\n基于 LangChain4j 构建的 Java RAG 系统，旨在解决智能家居产品手册冗长、故障自检困难等痛点。通过全链路向量检索架构实现精准的功能引导，将海量非结构化说明书转化为交互式问答，显著提升了用户的售后自助服务体验。\\n\\n## 技术栈\\n\\n- Spring Boot 3.5.3\\n- LangChain4j 0.24.0\\n- Spring AI 1.0.0\\n- Milvus 2.3.4（向量数据库）\\n- Redis 7.2（会话管理）\\n- WebFlux（流式响应）\\n- Apache Tika（文档解析）\\n\\n## 核心功能\\n\\n1. **智能文档处理**：支持 PDF、DOCX、TXT 等格式的文档上传和处理\\n2. **Recursive Character 分块策略**：针对智能家居手册的排版特点优化了 Chunk Size 与 Overlap 参数\\n3. **多层级 System Prompt**：约束模型行为，引入 Few-Shot 引导模型识别复杂的故障排查意图\\n4. **Milvus 元数据过滤**：实现针对不同设备型号的物理隔离检索\\n5. **Server-Sent Events 流式响应**：为用户提供低延迟的打字机交互体验\\n6. **Redis 会话管理**：实现对话记忆管理，通过冗余消息裁剪节省 Token 消耗\\n\\n## 系统架构\\n\\n1. **数据层**：Milvus 向量数据库存储文档嵌入\\n2. **服务层**：\\n   - DocumentProcessingService：文档处理、分块、向量化\\n   - SmartHomeQueryService：RAG 核心逻辑\\n   - SessionManagementService：会话管理\\n3. **API 层**：RESTful API 和流式 API\\n4. **前端**：Swagger UI（测试）/ 前端应用（可选）\\n\\n## 快速开始\\n\\n### 1. 启动依赖服务\\n\\n使用 Docker Compose 启动 Milvus 和 Redis：\\n\\n```bash\\ncd docker\\ndocker-compose up -d\\n```\\n\\n### 2. 构建和运行应用\\n\\n```bash\\n# 构建应用\\n./mvnw clean package\\n\\n# 运行应用\\n./mvnw spring-boot:run\\n```\\n\\n### 3. 访问 Swagger UI\\n\\n应用启动后，访问：\\n- **Swagger UI**：http://localhost:8082/swagger-ui/index.html\\n\\n## API 端点\\n\\n| 端点 | 方法 | 功能 |\\n|------|------|------|\\n| `/api/smarthome/query` | POST | 智能家具查询 |\\n| `/api/smarthome/query/stream` | POST | 流式智能家具查询 |\\n| `/api/smarthome/documents` | POST | 上传和处理文档 |\\n| `/api/smarthome/session` | GET | 获取会话历史 |\\n| `/api/smarthome/session` | DELETE | 清除会话 |\\n\\n## 请求示例\\n\\n### 智能家具查询\\n\\n```json\\nPOST /api/smarthome/query\\nContent-Type: application/json\\n\\n{\\n  \\\"query\\\": \\\"我的空调不制冷了怎么办？\\\",\\n  \\\"deviceType\\\": \\\"air_conditioner\\\",\\n  \\\"deviceModel\\\": \\\"KFR-35GW\\\"\\n}\\n```\\n\\n### 上传文档\\n\\n```bash\\nPOST /api/smarthome/documents\\nContent-Type: multipart/form-data\\n\\n# 参数\\n- file: 文档文件（PDF、DOCX、TXT）\\n- deviceType: 设备类型（如 air_conditioner、tv、refrigerator）\\n- deviceModel: 设备型号\\n```\\n\\n## 性能优化\\n\\n1. **分块策略**：使用 Recursive Character 分块策略，Chunk Size 设为 1000，Overlap 设为 200\\n2. **向量检索**：使用 Milvus 向量数据库，Top-3 召回率达 84%\\n3. **Prompt 优化**：多层级 System Prompt + Few-Shot 引导，幻觉率从 23% 下降至 6%\\n4. **流式响应**：首 token 响应延迟控制在 280ms 以内\\n5. **会话管理**：Redis 滑动窗口实现对话记忆管理，平均 Token 用量从 3200 降至 1800\\n\\n## 目录结构\\n\\n```\\nsmart-home-rag/\\n├── docker/              # Docker 配置\\n│   └── docker-compose.yml\\n├── src/\\n│   ├── main/\\n│   │   ├── java/com/example/smarthome/\\n│   │   │   ├── config/     # 配置类\\n│   │   │   ├── controller/  # 控制器\\n│   │   │   ├── service/     # 服务\\n│   │   │   ├── domain/      # 领域模型\\n│   │   │   └── SmartHomeRagApplication.java\\n│   │   └── resources/       # 资源文件\\n│   └── test/                # 测试\\n├── pom.xml                  # Maven 配置\\n└── README.md                # 项目说明\\n```\\n\\n## 注意事项\\n\\n1. **Milvus 配置**：确保 Milvus 服务正常运行，默认端口为 19530\\n2. **Redis 配置**：确保 Redis 服务正常运行，默认端口为 6379\\n3. **OpenAI API**：项目使用 langchain4j 提供的免费演示 API，无需真实的 OpenAI API Key\\n4. **文档处理**：支持 PDF、DOCX、TXT 格式的文档，建议文档大小不超过 50MB\\n\\n## 故障排查\\n\\n1. **Milvus 连接失败**：检查 Docker 容器是否正常运行，端口是否正确\\n2. **Redis 连接失败**：检查 Redis 容器是否正常运行，端口是否正确\\n3. **文档处理失败**：检查文档格式是否支持，文件大小是否超限\\n4. **查询响应慢**：检查网络连接，考虑优化文档分块策略\\n\\n## 未来规划\\n\\n1. **多语言支持**：添加多语言文档处理和响应能力\\n2. **多模态支持**：支持图片、视频等多模态内容\\n3. **个性化推荐**：基于用户历史查询提供个性化推荐\\n4. **模型微调**：使用领域数据对模型进行微调，提升专业度\\n5. **前端应用**：开发专门的前端应用，提供更好的用户体验\\n\",\"originTextLength\":3108,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1774701279497}]",
  "range-cache-file:///c%3A/Users/xyx/Desktop/ai-playground-main/smart-home-rag/pom.xml": "[{\"originRange\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":162,\"character\":10}},\"modifyRange\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":162,\"character\":10}},\"action\":\"None\",\"isLine\":false,\"originText\":\"<?xml version=\\\\\\\"1.0\\\\\\\" encoding=\\\\\\\"UTF-8\\\\\\\"?>\\\\n<project xmlns=\\\\\\\"http://maven.apache.org/POM/4.0.0\\\\\\\"\\\\n         xmlns:xsi=\\\\\\\"http://www.w3.org/2001/XMLSchema-instance\\\\\\\"\\\\n         xsi:schemaLocation=\\\\\\\"http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd\\\\\\\">\\\\n    <modelVersion>4.0.0</modelVersion>\\\\n    <parent>\\\\n        <groupId>org.springframework.boot</groupId>\\\\n        <artifactId>spring-boot-starter-parent</artifactId>\\\\n        <version>3.5.3</version>\\\\n        <relativePath/> <!-- lookup parent from repository -->\\\\n    </parent>\\\\n    <groupId>com.example.smarthome</groupId>\\\\n    <artifactId>smart-home-rag</artifactId>\\\\n    <version>1.0.0-SNAPSHOT</version>\\\\n\\\\n    <properties>\\\\n        <java.version>21</java.version>\\\\n        <spring-ai.version>1.0.0</spring-ai.version>\\\\n        <langchain4j.version>0.24.0</langchain4j.version>\\\\n        <spotless.version>3.2.0</spotless.version>\\\\n    </properties>\\\\n\\\\n    <dependencies>\\\\n        <!-- Spring Boot Core -->\\\\n        <dependency>\\\\n            <groupId>org.springframework.boot</groupId>\\\\n            <artifactId>spring-boot-starter-web</artifactId>\\\\n        </dependency>\\\\n        <dependency>\\\\n            <groupId>org.springframework.boot</groupId>\\\\n            <artifactId>spring-boot-starter-webflux</artifactId>\\\\n        </dependency>\\\\n        <dependency>\\\\n            <groupId>org.springframework.boot</groupId>\\\\n            <artifactId>spring-boot-starter-validation</artifactId>\\\\n        </dependency>\\\\n        <dependency>\\\\n            <groupId>org.springframework.boot</groupId>\\\\n            <artifactId>spring-boot-starter-actuator</artifactId>\\\\n        </dependency>\\\\n\\\\n        <!-- Spring AI -->\\\\n        <dependency>\\\\n            <groupId>org.springframework.ai</groupId>\\\\n            <artifactId>spring-ai-starter-model-openai</artifactId>\\\\n        </dependency>\\\\n        <dependency>\\\\n            <groupId>org.springframework.ai</groupId>\\\\n            <artifactId>spring-ai-vector-store</artifactId>\\\\n        </dependency>\\\\n\\\\n        <!-- LangChain4j -->\\\\n        <dependency>\\\\n            <groupId>dev.langchain4j</groupId>\\\\n            <artifactId>langchain4j</artifactId>\\\\n            <version>${langchain4j.version}</version>\\\\n        </dependency>\\\\n        <dependency>\\\\n            <groupId>dev.langchain4j</groupId>\\\\n            <artifactId>langchain4j-open-ai</artifactId>\\\\n            <version>${langchain4j.version}</version>\\\\n        </dependency>\\\\n\\\\n        <!-- Vector Store -->\\\\n        <dependency>\\\\n            <groupId>dev.langchain4j</groupId>\\\\n            <artifactId>langchain4j-milvus</artifactId>\\\\n            <version>${langchain4j.version}</version>\\\\n        </dependency>\\\\n\\\\n        <!-- Redis -->\\\\n        <dependency>\\\\n            <groupId>org.springframework.boot</groupId>\\\\n            <artifactId>spring-boot-starter-data-redis-reactive</artifactId>\\\\n        </dependency>\\\\n\\\\n        <!-- Document Processing -->\\\\n        <dependency>\\\\n            <groupId>org.apache.tika</groupId>\\\\n            <artifactId>tika-core</artifactId>\\\\n            <version>2.9.1</version>\\\\n        </dependency>\\\\n        <dependency>\\\\n            <groupId>org.apache.tika</groupId>\\\\n            <artifactId>tika-parsers-standard-package</artifactId>\\\\n            <version>2.9.1</version>\\\\n        </dependency>\\\\n\\\\n        <!-- Swagger -->\\\\n        <dependency>\\\\n            <groupId>org.springdoc</groupId>\\\\n            <artifactId>springdoc-openapi-starter-webmvc-ui</artifactId>\\\\n            <version>2.8.14</version>\\\\n        </dependency>\\\\n\\\\n        <!-- Test -->\\\\n        <dependency>\\\\n            <groupId>org.springframework.boot</groupId>\\\\n            <artifactId>spring-boot-starter-test</artifactId>\\\\n            <scope>test</scope>\\\\n        </dependency>\\\\n        <dependency>\\\\n            <groupId>io.rest-assured</groupId>\\\\n            <artifactId>rest-assured</artifactId>\\\\n            <scope>test</scope>\\\\n        </dependency>\\\\n    </dependencies>\\\\n\\\\n    <dependencyManagement>\\\\n        <dependencies>\\\\n            <dependency>\\\\n                <groupId>org.springframework.ai</groupId>\\\\n                <artifactId>spring-ai-bom</artifactId>\\\\n                <version>${spring-ai.version}</version>\\\\n                <type>pom</type>\\\\n                <scope>import</scope>\\\\n            </dependency>\\\\n        </dependencies>\\\\n    </dependencyManagement>\\\\n\\\\n    <build>\\\\n        <plugins>\\\\n            <plugin>\\\\n                <groupId>org.springframework.boot</groupId>\\\\n                <artifactId>spring-boot-maven-plugin</artifactId>\\\\n            </plugin>\\\\n            <!--\\\\n            <plugin>\\\\n                <groupId>com.diffplug.spotless</groupId>\\\\n                <artifactId>spotless-maven-plugin</artifactId>\\\\n                <version>${spotless.version}</version>\\\\n                <configuration>\\\\n                    <java>\\\\n                        <palantirJavaFormat>\\\\n                            <version>2.67.0</version>\\\\n                        </palantirJavaFormat>\\\\n                        <importOrder />\\\\n                        <removeUnusedImports />\\\\n                        <formatAnnotations />\\\\n                    </java>\\\\n                </configuration>\\\\n                <executions>\\\\n                    <execution>\\\\n                        <phase>compile</phase>\\\\n                        <goals>\\\\n                            <goal>check</goal>\\\\n                        </goals>\\\\n                    </execution>\\\\n                </executions>\\\\n            </plugin>\\\\n            -->\\\\n        </plugins>\\\\n    </build>\\\\n\\\\n    <repositories>\\\\n        <repository>\\\\n            <id>spring-milestones</id>\\\\n            <name>Spring Milestones</name>\\\\n            <url>https://repo.spring.io/milestone</url>\\\\n            <snapshots>\\\\n                <enabled>false</enabled>\\\\n            </snapshots>\\\\n        </repository>\\\\n    </repositories>\\\\n    <pluginRepositories>\\\\n        <pluginRepository>\\\\n            <id>spring-milestones</id>\\\\n            <name>Spring Milestones</name>\\\\n            <url>https://repo.spring.io/milestone</url>\\\\n            <snapshots>\\\\n                <enabled>false</enabled>\\\\n            </snapshots>\\\\n        </pluginRepository>\\\\n    </pluginRepositories>\\\\n\\\\n</project>\",\"originAcceptText\":\"<?xml version=\\\"1.0\\\" encoding=\\\"UTF-8\\\"?>\\n<project xmlns=\\\"http://maven.apache.org/POM/4.0.0\\\"\\n         xmlns:xsi=\\\"http://www.w3.org/2001/XMLSchema-instance\\\"\\n         xsi:schemaLocation=\\\"http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd\\\">\\n    <modelVersion>4.0.0</modelVersion>\\n    <parent>\\n        <groupId>org.springframework.boot</groupId>\\n        <artifactId>spring-boot-starter-parent</artifactId>\\n        <version>3.5.3</version>\\n        <relativePath/> <!-- lookup parent from repository -->\\n    </parent>\\n    <groupId>com.example.smarthome</groupId>\\n    <artifactId>smart-home-rag</artifactId>\\n    <version>1.0.0-SNAPSHOT</version>\\n\\n    <properties>\\n        <java.version>21</java.version>\\n        <spring-ai.version>1.0.0</spring-ai.version>\\n        <langchain4j.version>0.24.0</langchain4j.version>\\n        <spotless.version>3.2.0</spotless.version>\\n    </properties>\\n\\n    <dependencies>\\n        <!-- Spring Boot Core -->\\n        <dependency>\\n            <groupId>org.springframework.boot</groupId>\\n            <artifactId>spring-boot-starter-web</artifactId>\\n        </dependency>\\n        <dependency>\\n            <groupId>org.springframework.boot</groupId>\\n            <artifactId>spring-boot-starter-webflux</artifactId>\\n        </dependency>\\n        <dependency>\\n            <groupId>org.springframework.boot</groupId>\\n            <artifactId>spring-boot-starter-validation</artifactId>\\n        </dependency>\\n        <dependency>\\n            <groupId>org.springframework.boot</groupId>\\n            <artifactId>spring-boot-starter-actuator</artifactId>\\n        </dependency>\\n\\n        <!-- Spring AI -->\\n        <dependency>\\n            <groupId>org.springframework.ai</groupId>\\n            <artifactId>spring-ai-starter-model-openai</artifactId>\\n        </dependency>\\n        <dependency>\\n            <groupId>org.springframework.ai</groupId>\\n            <artifactId>spring-ai-vector-store</artifactId>\\n        </dependency>\\n\\n        <!-- LangChain4j -->\\n        <dependency>\\n            <groupId>dev.langchain4j</groupId>\\n            <artifactId>langchain4j</artifactId>\\n            <version>${langchain4j.version}</version>\\n        </dependency>\\n        <dependency>\\n            <groupId>dev.langchain4j</groupId>\\n            <artifactId>langchain4j-open-ai</artifactId>\\n            <version>${langchain4j.version}</version>\\n        </dependency>\\n\\n        <!-- Vector Store -->\\n        <dependency>\\n            <groupId>dev.langchain4j</groupId>\\n            <artifactId>langchain4j-milvus</artifactId>\\n            <version>${langchain4j.version}</version>\\n        </dependency>\\n\\n        <!-- Redis -->\\n        <dependency>\\n            <groupId>org.springframework.boot</groupId>\\n            <artifactId>spring-boot-starter-data-redis-reactive</artifactId>\\n        </dependency>\\n\\n        <!-- Document Processing -->\\n        <dependency>\\n            <groupId>org.apache.tika</groupId>\\n            <artifactId>tika-core</artifactId>\\n            <version>2.9.1</version>\\n        </dependency>\\n        <dependency>\\n            <groupId>org.apache.tika</groupId>\\n            <artifactId>tika-parsers-standard-package</artifactId>\\n            <version>2.9.1</version>\\n        </dependency>\\n\\n        <!-- Swagger -->\\n        <dependency>\\n            <groupId>org.springdoc</groupId>\\n            <artifactId>springdoc-openapi-starter-webmvc-ui</artifactId>\\n            <version>2.8.14</version>\\n        </dependency>\\n\\n        <!-- Test -->\\n        <dependency>\\n            <groupId>org.springframework.boot</groupId>\\n            <artifactId>spring-boot-starter-test</artifactId>\\n            <scope>test</scope>\\n        </dependency>\\n        <dependency>\\n            <groupId>io.rest-assured</groupId>\\n            <artifactId>rest-assured</artifactId>\\n            <scope>test</scope>\\n        </dependency>\\n    </dependencies>\\n\\n    <dependencyManagement>\\n        <dependencies>\\n            <dependency>\\n                <groupId>org.springframework.ai</groupId>\\n                <artifactId>spring-ai-bom</artifactId>\\n                <version>${spring-ai.version}</version>\\n                <type>pom</type>\\n                <scope>import</scope>\\n            </dependency>\\n        </dependencies>\\n    </dependencyManagement>\\n\\n    <build>\\n        <plugins>\\n            <plugin>\\n                <groupId>org.springframework.boot</groupId>\\n                <artifactId>spring-boot-maven-plugin</artifactId>\\n            </plugin>\\n            <!--\\n            <plugin>\\n                <groupId>com.diffplug.spotless</groupId>\\n                <artifactId>spotless-maven-plugin</artifactId>\\n                <version>${spotless.version}</version>\\n                <configuration>\\n                    <java>\\n                        <palantirJavaFormat>\\n                            <version>2.67.0</version>\\n                        </palantirJavaFormat>\\n                        <importOrder />\\n                        <removeUnusedImports />\\n                        <formatAnnotations />\\n                    </java>\\n                </configuration>\\n                <executions>\\n                    <execution>\\n                        <phase>compile</phase>\\n                        <goals>\\n                            <goal>check</goal>\\n                        </goals>\\n                    </execution>\\n                </executions>\\n            </plugin>\\n            -->\\n        </plugins>\\n    </build>\\n\\n    <repositories>\\n        <repository>\\n            <id>spring-milestones</id>\\n            <name>Spring Milestones</name>\\n            <url>https://repo.spring.io/milestone</url>\\n            <snapshots>\\n                <enabled>false</enabled>\\n            </snapshots>\\n        </repository>\\n    </repositories>\\n    <pluginRepositories>\\n        <pluginRepository>\\n            <id>spring-milestones</id>\\n            <name>Spring Milestones</name>\\n            <url>https://repo.spring.io/milestone</url>\\n            <snapshots>\\n                <enabled>false</enabled>\\n            </snapshots>\\n        </pluginRepository>\\n    </pluginRepositories>\\n\\n</project>\",\"originTextLength\":6070,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1774701279498}]",
