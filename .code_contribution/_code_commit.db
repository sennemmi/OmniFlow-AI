  "range-cache-file:///c%3A/Users/xyx/Desktop/ai-playground-main/smart-home-rag/src/main/java/com/example/smarthome/controller/SmartHomeController.java": "[{\"originRange\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":93,\"character\":0}},\"modifyRange\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":93,\"character\":0}},\"action\":\"None\",\"isLine\":false,\"originText\":\"package com.example.smarthome.controller;\\\\n\\\\nimport com.example.smarthome.domain.request.SmartHomeQueryRequest;\\\\nimport com.example.smarthome.domain.response.SmartHomeQueryResponse;\\\\nimport com.example.smarthome.domain.response.SmartHomeStreamResponse;\\\\nimport com.example.smarthome.service.DocumentProcessingService;\\\\nimport com.example.smarthome.service.SessionManagementService;\\\\nimport com.example.smarthome.service.SmartHomeQueryService;\\\\nimport jakarta.validation.Valid;\\\\nimport org.slf4j.Logger;\\\\nimport org.slf4j.LoggerFactory;\\\\nimport org.springframework.core.io.Resource;\\\\nimport org.springframework.http.MediaType;\\\\nimport org.springframework.web.bind.annotation.*;\\\\nimport org.springframework.web.multipart.MultipartFile;\\\\n\\\\nimport java.io.IOException;\\\\nimport java.nio.file.Files;\\\\nimport java.nio.file.Path;\\\\nimport java.nio.file.StandardCopyOption;\\\\nimport java.util.List;\\\\n\\\\n@RestController\\\\n@RequestMapping(\\\\\\\"/api/smarthome\\\\\\\")\\\\npublic class SmartHomeController {\\\\n\\\\n    private static final Logger logger = LoggerFactory.getLogger(SmartHomeController.class);\\\\n\\\\n    private final SmartHomeQueryService smartHomeQueryService;\\\\n    private final DocumentProcessingService documentProcessingService;\\\\n    private final SessionManagementService sessionManagementService;\\\\n\\\\n    public SmartHomeController(\\\\n            SmartHomeQueryService smartHomeQueryService,\\\\n            DocumentProcessingService documentProcessingService,\\\\n            SessionManagementService sessionManagementService) {\\\\n        this.smartHomeQueryService = smartHomeQueryService;\\\\n        this.documentProcessingService = documentProcessingService;\\\\n        this.sessionManagementService = sessionManagementService;\\\\n    }\\\\n\\\\n    /**\\\\n     * 处理智能家具查询\\\\n     */\\\\n    @PostMapping(\\\\\\\"/query\\\\\\\")\\\\n    public SmartHomeQueryResponse query(@Valid @RequestBody SmartHomeQueryRequest request) {\\\\n        logger.info(\\\\\\\"Received query: {} for device {} {}\\\\\\\", request.query(), request.deviceType(), request.deviceModel());\\\\n        return smartHomeQueryService.query(request);\\\\n    }\\\\n\\\\n    /**\\\\n     * 处理流式智能家具查询\\\\n     */\\\\n    @PostMapping(value = \\\\\\\"/query/stream\\\\\\\", produces = MediaType.TEXT_EVENT_STREAM_VALUE)\\\\n    public SmartHomeStreamResponse streamQuery(@Valid @RequestBody SmartHomeQueryRequest request) {\\\\n        logger.info(\\\\\\\"Received stream query: {} for device {} {}\\\\\\\", request.query(), request.deviceType(), request.deviceModel());\\\\n        return smartHomeQueryService.streamQuery(request);\\\\n    }\\\\n\\\\n    /**\\\\n     * 上传和处理文档\\\\n     */\\\\n    @PostMapping(\\\\\\\"/documents\\\\\\\")\\\\n    public String uploadDocument(\\\\n            @RequestParam(\\\\\\\"file\\\\\\\") MultipartFile file,\\\\n            @RequestParam(\\\\\\\"deviceType\\\\\\\") String deviceType,\\\\n            @RequestParam(\\\\\\\"deviceModel\\\\\\\") String deviceModel) {\\\\n        try {\\\\n            // 保存文件到临时目录\\\\n            Path tempFile = Files.createTempFile(\\\\\\\"smart-home\\\\\\\", file.getOriginalFilename());\\\\n            Files.copy(file.getInputStream(), tempFile, StandardCopyOption.REPLACE_EXISTING);\\\\n\\\\n            // 处理文档\\\\n            documentProcessingService.processDocument(\\\\n                    new org.springframework.core.io.FileSystemResource(tempFile.toFile()),\\\\n                    deviceType,\\\\n                    deviceModel\\\\n            );\\\\n\\\\n            // 清理临时文件\\\\n            Files.deleteIfExists(tempFile);\\\\n\\\\n            logger.info(\\\\\\\"Processed document: {} for device {} {}\\\\\\\", file.getOriginalFilename(), deviceType, deviceModel);\\\\n            return \\\\\\\"Document processed successfully\\\\\\\";\\\\n        } catch (IOException e) {\\\\n            logger.error(\\\\\\\"Error processing document: {}\\\\\\\", file.getOriginalFilename(), e);\\\\n            return \\\\\\\"Error processing document: \\\\\\\" + e.getMessage();\\\\n        }\\\\n    }\\\\n\\\\n    /**\\\\n     * 获取会话历史\\\\n     */\\\\n    @GetMapping(\\\\\\\"/session\\\\\\\")\\\\n    public List<String> getSessionHistory() {\\\\n        return sessionManagementService.getSessionHistory();\\\\n    }\\\\n\\\\n    /**\\\\n     * 清除会话\\\\n     */\\\\n    @DeleteMapping(\\\\\\\"/session\\\\\\\")\\\\n    public String clearSession() {\\\\n        sessionManagementService.clearSession();\\\\n        return \\\\\\\"Session cleared successfully\\\\\\\";\\\\n    }\\\\n}\\\\n\",\"originAcceptText\":\"package com.example.smarthome.controller;\\n\\nimport com.example.smarthome.domain.request.SmartHomeQueryRequest;\\nimport com.example.smarthome.domain.response.SmartHomeQueryResponse;\\nimport com.example.smarthome.domain.response.SmartHomeStreamResponse;\\nimport com.example.smarthome.service.DocumentProcessingService;\\nimport com.example.smarthome.service.SessionManagementService;\\nimport com.example.smarthome.service.SmartHomeQueryService;\\nimport jakarta.validation.Valid;\\nimport org.slf4j.Logger;\\nimport org.slf4j.LoggerFactory;\\nimport org.springframework.core.io.Resource;\\nimport org.springframework.http.MediaType;\\nimport org.springframework.web.bind.annotation.*;\\nimport org.springframework.web.multipart.MultipartFile;\\n\\nimport java.io.IOException;\\nimport java.nio.file.Files;\\nimport java.nio.file.Path;\\nimport java.nio.file.StandardCopyOption;\\nimport java.util.List;\\n\\n@RestController\\n@RequestMapping(\\\"/api/smarthome\\\")\\npublic class SmartHomeController {\\n\\n    private static final Logger logger = LoggerFactory.getLogger(SmartHomeController.class);\\n\\n    private final SmartHomeQueryService smartHomeQueryService;\\n    private final DocumentProcessingService documentProcessingService;\\n    private final SessionManagementService sessionManagementService;\\n\\n    public SmartHomeController(\\n            SmartHomeQueryService smartHomeQueryService,\\n            DocumentProcessingService documentProcessingService,\\n            SessionManagementService sessionManagementService) {\\n        this.smartHomeQueryService = smartHomeQueryService;\\n        this.documentProcessingService = documentProcessingService;\\n        this.sessionManagementService = sessionManagementService;\\n    }\\n\\n    /**\\n     * 处理智能家具查询\\n     */\\n    @PostMapping(\\\"/query\\\")\\n    public SmartHomeQueryResponse query(@Valid @RequestBody SmartHomeQueryRequest request) {\\n        logger.info(\\\"Received query: {} for device {} {}\\\", request.query(), request.deviceType(), request.deviceModel());\\n        return smartHomeQueryService.query(request);\\n    }\\n\\n    /**\\n     * 处理流式智能家具查询\\n     */\\n    @PostMapping(value = \\\"/query/stream\\\", produces = MediaType.TEXT_EVENT_STREAM_VALUE)\\n    public SmartHomeStreamResponse streamQuery(@Valid @RequestBody SmartHomeQueryRequest request) {\\n        logger.info(\\\"Received stream query: {} for device {} {}\\\", request.query(), request.deviceType(), request.deviceModel());\\n        return smartHomeQueryService.streamQuery(request);\\n    }\\n\\n    /**\\n     * 上传和处理文档\\n     */\\n    @PostMapping(\\\"/documents\\\")\\n    public String uploadDocument(\\n            @RequestParam(\\\"file\\\") MultipartFile file,\\n            @RequestParam(\\\"deviceType\\\") String deviceType,\\n            @RequestParam(\\\"deviceModel\\\") String deviceModel) {\\n        try {\\n            // 保存文件到临时目录\\n            Path tempFile = Files.createTempFile(\\\"smart-home\\\", file.getOriginalFilename());\\n            Files.copy(file.getInputStream(), tempFile, StandardCopyOption.REPLACE_EXISTING);\\n\\n            // 处理文档\\n            documentProcessingService.processDocument(\\n                    new org.springframework.core.io.FileSystemResource(tempFile.toFile()),\\n                    deviceType,\\n                    deviceModel\\n            );\\n\\n            // 清理临时文件\\n            Files.deleteIfExists(tempFile);\\n\\n            logger.info(\\\"Processed document: {} for device {} {}\\\", file.getOriginalFilename(), deviceType, deviceModel);\\n            return \\\"Document processed successfully\\\";\\n        } catch (IOException e) {\\n            logger.error(\\\"Error processing document: {}\\\", file.getOriginalFilename(), e);\\n            return \\\"Error processing document: \\\" + e.getMessage();\\n        }\\n    }\\n\\n    /**\\n     * 获取会话历史\\n     */\\n    @GetMapping(\\\"/session\\\")\\n    public List<String> getSessionHistory() {\\n        return sessionManagementService.getSessionHistory();\\n    }\\n\\n    /**\\n     * 清除会话\\n     */\\n    @DeleteMapping(\\\"/session\\\")\\n    public String clearSession() {\\n        sessionManagementService.clearSession();\\n        return \\\"Session cleared successfully\\\";\\n    }\\n}\\n\",\"originTextLength\":3988,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1774701279504}]",
