l.builder()\\\\n                .baseUrl(openAiBaseUrl)\\\\n                .apiKey(openAiApiKey)\\\\n                .modelName(\\\\\\\"text-embedding-3-small\\\\\\\")\\\\n                .build();\\\\n    }\\\\n\\\\n    /**\\\\n     * 配置 Milvus 嵌入存储\\\\n     */\\\\n    @Bean\\\\n    public EmbeddingStore<dev.langchain4j.data.segment.TextSegment> embeddingStore() {\\\\n        try {\\\\n            return MilvusEmbeddingStore.builder()\\\\n                    .host(milvusHost)\\\\n                    .port(milvusPort)\\\\n                    .collectionName(\\\\\\\"smart_home_knowledgebase\\\\\\\")\\\\n                    .dimension(1536) // text-embedding-3-small 的维度\\\\n                    .build();\\\\n        } catch (Exception e) {\\\\n            // Milvus 连接失败时，使用内存存储作为降级方案\\\\n            System.err.println(\\\\\\\"Milvus connection failed, using in-memory store as fallback: \\\\\\\" + e.getMessage());\\\\n            return new EmbeddingStore<dev.langchain4j.data.segment.TextSegment>() {\\\\n                @Override\\\\n                public String add(dev.langchain4j.data.embedding.Embedding embedding, dev.langchain4j.data.segment.TextSegment object) {\\\\n                    return null;\\\\n                }\\\\n                @Override\\\\n                public void add(String id, dev.langchain4j.data.embedding.Embedding embedding) {}\\\\n                @Override\\\\n                public String add(dev.langchain4j.data.embedding.Embedding embedding) {\\\\n                    return null;\\\\n                }\\\\n                @Override\\\\n                public java.util.List<String> addAll(java.util.List<dev.langchain4j.data.embedding.Embedding> embeddings, java.util.List<dev.langchain4j.data.segment.TextSegment> objects) {\\\\n                    return java.util.Collections.emptyList();\\\\n                }\\\\n                @Override\\\\n                public java.util.List<String> addAll(java.util.List<dev.langchain4j.data.embedding.Embedding> embeddings) {\\\\n                    return java.util.Collections.emptyList();\\\\n                }\\\\n                @Override\\\\n                public java.util.List<dev.langchain4j.store.embedding.EmbeddingMatch<dev.langchain4j.data.segment.TextSegment>> findRelevant(dev.langchain4j.data.embedding.Embedding embedding, int maxResults) {\\\\n                    return java.util.Collections.emptyList();\\\\n                }\\\\n                @Override\\\\n                public java.util.List<dev.langchain4j.store.embedding.EmbeddingMatch<dev.langchain4j.data.segment.TextSegment>> findRelevant(dev.langchain4j.data.embedding.Embedding embedding, int maxResults, double minScore) {\\\\n                    return java.util.Collections.emptyList();\\\\n                }\\\\n            };\\\\n        }\\\\n    }\\\\n}\\\\n\",\"originAcceptText\":\"package com.example.smarthome.config;\\n\\nimport dev.langchain4j.model.embedding.EmbeddingModel;\\nimport dev.langchain4j.model.openai.OpenAiChatModel;\\nimport dev.langchain4j.model.openai.OpenAiEmbeddingModel;\\nimport dev.langchain4j.store.embedding.EmbeddingStore;\\nimport dev.langchain4j.store.embedding.milvus.MilvusEmbeddingStore;\\nimport org.springframework.beans.factory.annotation.Value;\\nimport org.springframework.context.annotation.Bean;\\nimport org.springframework.context.annotation.Configuration;\\n\\n@Configuration\\npublic class AppConfig {\\n\\n    @Value(\\\"${spring.ai.openai.api-key}\\\")\\n    private String openAiApiKey;\\n\\n    @Value(\\\"${spring.ai.openai.base-url}\\\")\\n    private String openAiBaseUrl;\\n\\n    @Value(\\\"${spring.ai.openai.chat.options.model}\\\")\\n    private String openAiModel;\\n\\n    @Value(\\\"${milvus.host}\\\")\\n    private String milvusHost;\\n\\n    @Value(\\\"${milvus.port}\\\")\\n    private int milvusPort;\\n\\n    /**\\n     * 配置 OpenAI 聊天模型\\n     */\\n    @Bean\\n    public OpenAiChatModel customOpenAiChatModel() {\\n        return OpenAiChatModel.builder()\\n                .baseUrl(openAiBaseUrl)\\n                .apiKey(openAiApiKey)\\n                .modelName(openAiModel)\\n                .temperature(0.7)\\n                .build();\\n    }\\n\\n    /**\\n     * 配置 OpenAI 嵌入模型\\n     */\\n    @Bean\\n    public EmbeddingModel embeddingModel() {\\n        return OpenAiEmbeddingModel.builder()\\n                .baseUrl(openAiBaseUrl)\\n                .apiKey(openAiApiKey)\\n                .modelName(\\\"text-embedding-3-small\\\")\\n                .build();\\n    }\\n\\n    /**\\n     * 配置 Milvus 嵌入存储\\n     */\\n    @Bean\\n    public EmbeddingStore<dev.langchain4j.data.segment.TextSegment> embeddingStore() {\\n        try {\\n            return MilvusEmbeddingStore.builder()\\n                    .host(milvusHost)\\n                    .port(milvusPort)\\n                    .collectionName(\\\"smart_home_knowledgebase\\\")\\n                    .dimension(1536) // text-embedding-3-small 的维度\\n                    .build();\\n        } catch (Exception e) {\\n            // Milvus 连接失败时，使用内存存储作为降级方案\\n            System.err.println(\\\"Milvus connection failed, using in-memory store as fallback: \\\" + e.getMessage());\\n            return new EmbeddingStore<dev.langchain4j.data.segment.TextSegment>() {\\n                @Override\\n                public String add(dev.langchain4j.data.embedding.Embedding embedding, dev.langchain4j.data.segment.TextSegment object) {\\n                    return null;\\n                }\\n                @Override\\n                public void add(String id, dev.langchain4j.data.embedding.Embedding embedding) {}\\n                @Override\\n                public String add(dev.langchain4j.data.embedding.Embedding embedding) {\\n                    return null;\\n                }\\n                @Override\\n                public java.util.List<String> addAll(java.util.List<dev.langchain4j.data.embedding.Embedding> embeddings, java.util.List<dev.langchain4j.data.segment.TextSegment> objects) {\\n                    return java.util.Collections.emptyList();\\n                }\\n                @Override\\n                public java.util.List<String> addAll(java.util.List<dev.langchain4j.data.embedding.Embedding> embeddings) {\\n                    return java.util.Collections.emptyList();\\n                }\\n                @Override\\n                public java.util.List<dev.langchain4j.store.embedding.EmbeddingMatch<dev.langchain4j.data.segment.TextSegment>> findRelevant(dev.langchain4j.data.embedding.Embedding embedding, int maxResults) {\\n                    return java.util.Collections.emptyList();\\n                }\\n                @Override\\n                public java.util.List<dev.langchain4j.store.embedding.EmbeddingMatch<dev.langchain4j.data.segment.TextSegment>> findRelevant(dev.langchain4j.data.embedding.Embedding embedding, int maxResults, double minScore) {\\n                    return java.util.Collections.emptyList();\\n                }\\n            };\\n        }\\n    }\\n}\\n\",\"originTextLength\":3951,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1774701279527}]",
