riginAcceptText\":\"version: '3.8'\\n\\nservices:\\n  # Milvus 向量数据库\\n  milvus:\\n    image: milvusdb/milvus:v2.3.4\\n    container_name: milvus\\n    ports:\\n      - \\\"19530:19530\\\"\\n      - \\\"9091:9091\\\"\\n    volumes:\\n      - ./milvus_data:/var/lib/milvus\\n    environment:\\n      - MILVUS_ETCD_ENDPOINTS=http://etcd:2379\\n      - MILVUS_MINIO_ENDPOINT=http://minio:9000\\n    depends_on:\\n      - etcd\\n      - minio\\n    networks:\\n      - smart-home-network\\n\\n  # Etcd 用于 Milvus 的元数据存储\\n  etcd:\\n    image: bitnami/etcd:3.5.10\\n    container_name: etcd\\n    environment:\\n      - ETCD_ROOT_PASSWORD=smart-home-etcd-password\\n    volumes:\\n      - ./etcd_data:/bitnami/etcd\\n    networks:\\n      - smart-home-network\\n\\n  # Minio 用于 Milvus 的对象存储\\n  minio:\\n    image: minio/minio:RELEASE.2024-01-18T22-51-28Z\\n    container_name: minio\\n    ports:\\n      - \\\"9000:9000\\\"\\n      - \\\"9001:9001\\\"\\n    volumes:\\n      - ./minio_data:/data\\n    environment:\\n      - MINIO_ROOT_USER=minioadmin\\n      - MINIO_ROOT_PASSWORD=minioadmin123\\n    command: server /data --console-address \\\":9001\\\"\\n    networks:\\n      - smart-home-network\\n\\n  # Redis 用于会话管理\\n  redis:\\n    image: redis:7.2-alpine\\n    container_name: redis\\n    ports:\\n      - \\\"6379:6379\\\"\\n    volumes:\\n      - ./redis_data:/data\\n    networks:\\n      - smart-home-network\\n\\nnetworks:\\n  smart-home-network:\\n    driver: bridge\\n\",\"originTextLength\":1299,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1774701279523}]",
