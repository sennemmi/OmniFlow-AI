nt.prompt(prompt).call().content();\\n            return new AIChatResponse(answer);\\n        } catch (Exception e) {\\n            logger.error(\\\"Error in chatWithSystemPrompt: {}\\\", e.getMessage(), e);\\n            return new AIChatResponse(\\\"Error: \\\" + e.getMessage());\\n        }\",\"originTextLength\":590,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1774620377876},{\"originRange\":{\"start\":{\"line\":75,\"character\":0},\"end\":{\"line\":83,\"character\":9}},\"modifyRange\":{\"start\":{\"line\":75,\"character\":0},\"end\":{\"line\":83,\"character\":9}},\"action\":\"None\",\"isLine\":false,\"originText\":\"        try {\\\\n            AssistantPromptTemplate promptTemplate = new AssistantPromptTemplate(SENTIMENT_ANALYSIS_TEMPLATE);\\\\n            Prompt prompt = promptTemplate.create(Map.of(\\\\\\\"query\\\\\\\", query));\\\\n            String answer = chatClient.prompt(prompt).call().content();\\\\n            return new AIChatResponse(answer);\\\\n        } catch (Exception e) {\\\\n            logger.error(\\\\\\\"Error in analyzeSentiment: {}\\\\\\\", e.getMessage(), e);\\\\n            return new AIChatResponse(\\\\\\\"Error: \\\\\\\" + e.getMessage());\\\\n        }\",\"originAcceptText\":\"        try {\\n            AssistantPromptTemplate promptTemplate = new AssistantPromptTemplate(SENTIMENT_ANALYSIS_TEMPLATE);\\n            Prompt prompt = promptTemplate.create(Map.of(\\\"query\\\", query));\\n            String answer = chatClient.prompt(prompt).call().content();\\n            return new AIChatResponse(answer);\\n        } catch (Exception e) {\\n            logger.error(\\\"Error in analyzeSentiment: {}\\\", e.getMessage(), e);\\n            return new AIChatResponse(\\\"Error: \\\" + e.getMessage());\\n        }\",\"originTextLength\":505,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1774620377877},{\"originRange\":{\"start\":{\"line\":82,\"character\":0},\"end\":{\"line\":88,\"character\":9