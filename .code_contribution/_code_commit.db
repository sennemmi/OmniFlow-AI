ents.\\\\\\\", similarDocuments.size());\",\"originAcceptText\":\"            // Step 2 retrieve related documents to query\\n            logger.info(\\\"Retrieving relevant documents\\\");\\n            List<Document> similarDocuments = simpleVectorStore.similaritySearch(\\n                    SearchRequest.builder().query(query).topK(2).build());\\n            \\n            // 检查是否找到相关文档\\n            if (similarDocuments.isEmpty()) {\\n                return new AIChatResponse(\\\"No relevant documents found.\\\");\\n            }\\n            \\n            logger.info(\\\"Found {} relevant documents.\\\", similarDocuments.size());\",\"originTextLength\":541,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1774620377884},{\"originRange\":{\"start\":{\"line\":129,\"character\":0},\"end\":{\"line\":132,\"character\":67}},\"modifyRange\":{\"start\":{\"line\":129,\"character\":0},\"end\":{\"line\":132,\"character\":67}},\"action\":\"None\",\"isLine\":false,\"originText\":\"            List<String> contentList =\\\\n                    similarDocuments.stream().map(Document::getText).toList();\\\\n            PromptTemplate promptTemplate = new PromptTemplate(ragPromptTemplate);\\\\n            Map<String, Object> promptParameters = new HashMap<>();\",\"originAcceptText\":\"            List<String> contentList =\\n                    similarDocuments.stream().map(Document::getText).toList();\\n            PromptTemplate promptTemplate = new PromptTemplate(ragPromptTemplate);\\n            Map<String, Object> promptParameters = new HashMap<>();\",\"originTextLength\":268,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1774620377885},{\"originRange\":{\"start\":{\"line\":134,\"character\":0},\"end\":{\"line\":136,\"character\":68}},\"modifyRange\":{\"start\":{\"line\":134,\"character\":0},\"end\":{\"line\":136,\"character\":68}},\"action\":\"None\",\"isLine\":false,\"originText\":\"            promptParameters.put(\\\\\\\"input\\\\\\\", query);\\\\n            promptParameters.put(\\\\\\\"documents\\\\\\\", String.join(\\\\\\\"\\\\\\\\n\\\\\\\", contentList));\\\\n            Prompt prompt = promptTemplate.create(promptParameters);\",\"originAcceptText\":\"            promptParameters.put(\\\"input\\\", query);\\n            promptParameters.put(\\\"documents\\\", String.join(\\\"\\\\n\\\", contentList));\\n            Prompt prompt = promptTemplate.create(promptParameters);\",\"originTextLength\":197,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1774620377886},{\"originRange\":{\"start\":{\"line\":138,\"character\":0},\"end\":{\"line\":144,\"character\":9}},\"modifyRange\":{\"start\":{\"line\":138,\"character\":0},\"end\":{\"line\":144,\"character\":9}},\"action\":\"None\",\"isLine\":false,\"originText\":\"            String response = chatClient.prompt(prompt).call().content();\\\\n            simpleVectorStore.delete(documents.stream().map(Document::getId).toList());\\\\n            return new AIChatResponse(response);\\\\n        } catch (Exception e) {\\\\n            logger.error(\\\\\\\"Error in ragGenerate: {}\\\\\\\", e.getMessage(), e);\\\\n            return new AIChatResponse(\\\\\\\"Error: \\\\\\\" + e.getMessage());\\\\n        }\",\"originAcceptText\":\"            String response = chatClient.prompt(prompt).call().content();\\n            simpleVectorStore.delete(documents.stream().map(Document::getId).toList());\\n            return new AIChatResponse(response);\\n        } catch (Exception e) {\\n            logger.error(\\\"Error in ragGenerate: {}\\\", e.getMessage(), e);\\n            return new AIChatResponse(\\\"Error: \\\" + e.getMessage());\\n        }\",\"originTextLength\":392,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1774620377887},{\"originRange\":{\"start\":{\"line\":144,\"character\":0},\"end\":{\"line\":149,\"character\":9}},\"modifyRange\":{\"start\":{\"line\":144,\"character\":0},\"end\":{\"line\":149,\"character\":9}},\"action\":\"None\",\"isLine\":false,\"originText\":\"        try {\\\\n            return chatClient.prompt(query).stream().content();\\\\n        } catch (Exception e) {\\\\n            logger.error(\\\\\\\"Error in streamChat: {}\\\\\\\", e.getMessage(), e);\\\\n            return Flux.just(\\\\\\\"Error: \\\\\\\" + e.getMessage());\\\\n        }\",\"originAcceptText\":\"        try {\\n            return chatClient.prompt(query).stream().content();\\n        } catch (Exception e) {\\n            logger.error(\\\"Error in streamChat: {}\\\", e.getMessage(), e);\\n            return Flux.just(\\\"Error: \\\" + e.getMessage());\\n        }\",\"originTextLength\":249,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1774620377888}]",
  "range-cache-file:///c%3A/Users/xyx/Desktop/ai-playground-main/smart-home-rag/src/main/java/com/example/smarthome/service/SmartHomeQueryService.java": "[{\"originRange\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":193,\"character\":0}},\"modifyRange\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":193,\"character\":0}},\"action\":\"None\",\"isLine\":false,\"originText\":\"package com.example.smarthome.service;\\\\n\\\\nimport com.example.smarthome.domain.request.SmartHomeQueryRequest;\\\\nimport com.example.smarthome.domain.response.SmartHomeQueryResponse;\\\\nimport com.example.smarthome.domain.response.SmartHomeStreamResponse;\\\\nimport dev.langchain4j.data.embedding.Embedding;\\\\nimport dev.langchain4j.data.segment.TextSegment;\\\\nimport dev.langchain4j.model.embedding.EmbeddingModel;\\\\nimport dev.langchain4j.model.input.Prompt;\\\\nimport dev.langchain4j.model.input.PromptTemplate;\\\\nimport dev.langchain4j.model.openai.OpenAiChatModel;\\\\nimport dev.langchain4j.store.embedding.EmbeddingMatch;\\\\nimport dev.langchain4j.store.embedding.EmbeddingSearchRequest;\\\\nimport dev.langchain4j.store.embedding.EmbeddingSearchResult;\\\\nimport dev.langchain4j.store.embedding.EmbeddingStore;\\\\nimport org.slf4j.Logger;\\\\nimport org.slf4j.LoggerFactory;\\\\nimport org.springframework.stereotype.Service;\\\\nimport reactor.core.publisher.Flux;\\\\n\\\\nimport java.time.Duration;\\\\nimport java.time.Instant;\\\\nimport java.util.List;\\\\nimport java.util.stream.Collectors;\\\\n\\\\n@Service\\\\npublic class SmartHomeQueryService {\\\\n\\\\n    private static final Logger logger = LoggerFactory.getLogger(SmartHomeQueryService.class);\\\\n\\\\n    private final EmbeddingModel embeddingModel;\\\\n    private final EmbeddingStore<TextSegment> embeddingStore;\\\\n    private final OpenAiChatModel chatModel;\\\\n    private final SessionManagementService sessionManagementService;\\\\n\\\\n    // 系统提示模板\\\\n    private static final String SYSTEM_PROMPT = \\\\\\\"\\\\\\\"\\\\\\\"\\\\n    你是一个专业的智能家居知识库助手，精通各种智能家居设备的使用和故障排查。\\\\n    你的任务是基于提供的文档内容，为用户提供准确、专业的回答。\\\\n    \\\\n    注意事项：\\\\n    1. 只基于提供的文档内容回答，不要添加文档中没有的信息\\\\n    2. 回答要清晰、简洁，避免使用专业术语\\\\n    3. 对于故障排查问题，提供详细的步骤指导\\\\n    4. 如果无法从文档中找到答案，诚实地告诉用户\\\\n    5. 保持友好、专业的语气\\\\n    \\\\\\\"\\\\\\\"\\\\\\\";\\\\n\\\\n    // 少样本提示模板\\\\n    private static final String FEW_SHOT_PROMPT = \\\\\\\"\\\\\\\"\\\\\\\"\\\\n    示例 1：\\\\n    用户问题：我的空调不制冷了怎么办？\\\\n    文档内容：当空调不制冷时，首先检查电源是否正常，然后检查温度设置是否正确，最后检查过滤网是否清洁。\\\\n    回答：当您的空调不制冷时，建议您按照以下步骤排查：\\\\n    1. 检查空调电源是否正常连接\\\\n    2. 确认温度设置是否低于当前室内温度\\\\n    3. 检查空调过滤网是否需要清洁\\\\n    \\\\n    示例 2：\\\\n    用户问题：如何设置电视的睡眠定时器？\\\\n    文档内容：要设置电视的睡眠定时器，首先进入设置菜单，选择时间设置，然后选择睡眠定时器，设置您希望电视关闭的时间。\\\\n    回答：要设置电视的睡眠定时器，请按照以下步骤操作：\\\\n    1. 按下遥控器上的\\\\\\\"菜单\\\\\\\"按钮\\\\n    2. 导航到\\\\\\\"设置\\\\\\\"选项\\\\n    3. 选择\\\\\\\"时间设置\\\\\\\"\\\\n    4. 选择\\\\\\\"睡眠定时器\\\\\\\"\\\\n    5. 设置您希望电视自动关闭的时间\\\\n    \\\\\\\"\\\\\\\"\\\\\\\";\\\\n\\\\n    // RAG 提示模板\\\\n    private static final String RAG_PROMPT_TEMPLATE = \\\\\\\"\\\\\\\"\\\\\\\"\\\\n    %s\\\\n    \\\\n    %s\\\\n    \\\\n    文档内容：\\\\n    %s\\\\n    \\\\n    用户问题：%s\\\\n    设备类型：%s\\\\n    设备型号：%s\\\\n    \\\\n    请基于上述文档内容回答用户问题，保持回答简洁明了。\\\\n    \\\\\\\"\\\\\\\"\\\\\\\";\\\\n\\\\n    public SmartHomeQueryService(\\\\n            EmbeddingModel embeddingModel,\\\\n            EmbeddingStore<TextSegment> embeddingStore,\\\\n            OpenAiChatModel chatModel,\\\\n            SessionManagementService sessionManagementService) {\\\\n        this.embeddingModel = embeddingModel;\\\\n        this.embeddingStore = embeddingStore;\\\\n        this.chatModel = chatModel;\\\\n        this.sessionManagementService = sessionManagementService;\\\\n    }\\\\n\\\\n    /**\\\\n     * 处理智能家具查询\\\\n     */\\\\n    public SmartHomeQueryResponse query(SmartHomeQueryRequest request) {\\\\n        Instant start = Instant.now();\\\\n\\\\n        try {\\\\n            // 1. 向量化查询\\\\n            Embedding queryEmbedding = embeddingModel.embed(request.query()).content();\\\\n\\\\n            // 2. 搜索相关文档\\\\n            EmbeddingSearchRequest searchRequest = EmbeddingSearchRequest.builder()\\\\n                    .queryEmbedding(queryEmbedding)\\\\n                    .maxResults(3) // Top-3 召回\\\\n                    .build();\\\\n\\\\n            EmbeddingSearchResult<TextSegment> searchResult = embeddingStore.search(searchRequest);\\\\n            List<EmbeddingMatch<TextSegment>> matches = searchResult.matches();\\\\n\\\\n            // 3. 构建上下文\\\\n            String context = matches.stream()\\\\n                    .map(match -> match.embedded().text())\\\\n                    .collect(Collectors.joining(\\\\\\\"\\\\\\\\n\\\\\\\\n\\\\\\\"));\\\\n\\\\n            // 4. 构建提示\\\\n            String promptText = String.format(\\\\n                    RAG_PROMPT_TEMPLATE,\\\\n                    SYSTEM_PROMPT,\\\\n                    FEW_SHOT_PROMPT,\\\\n                    context,\\\\n                    request.query(),\\\\n                    request.deviceType() != null ? request.deviceType() : \\\\\\\"未知\\\\\\\",\\\\n                    request.deviceModel() != null ? request.deviceModel() : \\\\\\\"未知\\\\\\\"\\\\n            );\\\\n\\\\n            Prompt prompt = new Prompt(promptText);\\\\n\\\\n            // 5. 生成回答\\\\n            String answer = chatModel.generate(prompt.text());\\\\n\\\\n            // 6. 提取来源\\\\n            List<String> sources = matches.stream()\\\\n                    .map(match -> {\\\\n                        TextSegment segment = match.embedded();\\\\n                        return segment.metadata().getOrDefault(\\\\\\\"source\\\\\\\", \\\\\\\"未知\\\\\\\");\\\\n                    })\\\\n                    .collect(Collectors.toList());\\\\n\\\\n            // 7. 计算置信度（基于相似度分数）\\\\n            double confidence = matches.stream()\\\\n                    .mapToDouble(EmbeddingMatch::score)\\\\n                    .average()\\\\n                    .orElse(0.0);\\\\n\\\\n            // 8. 记录会话\\\\n            sessionManagementService.addMessage(request.query(), answer);\\\\n\\\\n            long responseTime = Duration.between(start, Instant.now()).toMillis();\\\\n\\\\n            return new SmartHomeQueryResponse(answer, sources, confidence, responseTime);\\\\n        } catch (Exception e) {\\\\n            logger.error(\\\\\\\"Error processing query: {}\\\\\\\", request.query(), e);\\\\n            long responseTime = Duration.between(start, Instant.now()).toMillis();\\\\n            return new SmartHomeQueryResponse(\\\\n                    \\\\\\\"抱歉，处理您的请求时出现错误，请稍后再试。\\\\\\\",\\\\n                    List.of(),\\\\n                    0.0,\\\\n                    responseTime\\\\n            );\\\\n        }\\\\n    }\\\\n\\\\n    /**\\\\n     * 流式处理智能家具查询\\\\n     */\\\\n    public SmartHomeStreamResponse streamQuery(SmartHomeQueryRequest request) {\\\\n        try {\\\\n            // 1. 向量化查询\\\\n            Embedding queryEmbedding = embeddingModel.embed(request.query()).content();\\\\n\\\\n            // 2. 搜索相关文档\\\\n            EmbeddingSearchRequest searchRequest = EmbeddingSearchRequest.builder()\\\\n                    .queryEmbedding(queryEmbedding)\\\\n                    .maxResults(3)\\\\n                    .build();\\\\n\\\\n            EmbeddingSearchResult<TextSegment> searchResult = embeddingStore.search(searchRequest);\\\\n            List<EmbeddingMatch<TextSegment>> matches = searchResult.matches();\\\\n\\\\n            // 3. 构建上下文\\\\n            String context = matches.stream()\\\\n                    .map(match -> match.embedded().text())\\\\n                    .collect(Collectors.joining(\\\\\\\"\\\\\\\\n\\\\\\\\n\\\\\\\"));\\\\n\\\\n            // 4. 构建提示\\\\n            String promptText = String.format(\\\\n                    RAG_PROMPT_TEMPLATE,\\\\n                    SYSTEM_PROMPT,\\\\n                    FEW_SHOT_PROMPT,\\\\n                    context,\\\\n                    request.query(),\\\\n                    request.deviceType() != null ? request.deviceType() : \\\\\\\"未知\\\\\\\",\\\\n                    request.deviceModel() != null ? request.deviceModel() : \\\\\\\"未知\\\\\\\"\\\\n            );\\\\n\\\\n            // 5. 流式生成回答\\\\n            Flux<String> stream = Flux.create(sink -> {\\\\n                chatModel.generateStreaming(promptText, \\\\n                        chunk -> sink.next(chunk),\\\\n                        error -> sink.error(error),\\\\n                        () -> sink.complete()\\\\n                );\\\\n            });\\\\n\\\\n            // 6. 记录会话（异步）\\\\n            stream.collectList().subscribe(parts -> {\\\\n                String answer = String.join(\\\\\\\"\\\\\\\", parts);\\\\n                sessionManagementService.addMessage(request.query(), answer);\\\\n            });\\\\n\\\\n            return new SmartHomeStreamResponse(stream);\\\\n        } catch (Exception e) {\\\\n            logger.error(\\\\\\\"Error processing stream query: {}\\\\\\\", request.query(), e);\\\\n            return new SmartHomeStreamResponse(Flux.just(\\\\\\\"抱歉，处理您的请求时出现错误，请稍后再试。\\\\\\\"));\\\\n        }\\\\n    }\\\\n}\\\\n\",\"originAcceptText\":\"package com.example.smarthome.service;\\n\\nimport com.example.smarthome.domain.request.SmartHomeQueryRequest;\\nimport com.example.smarthome.domain.response.SmartHomeQueryResponse;\\nimport com.example.smarthome.domain.response.SmartHomeStreamResponse;\\nimport dev.langchain4j.data.embedding.Embedding;\\nimport dev.langchain4j.data.segment.TextSegment;\\nimport dev.langchain4j.model.embedding.EmbeddingModel;\\nimport dev.langchain4j.model.input.Prompt;\\nimport dev.langchain4j.model.input.PromptTemplate;\\nimport dev.langchain4j.model.openai.OpenAiChatModel;\\nimport dev.langchain4j.store.embedding.EmbeddingMatch;\\nimport dev.langchain4j.store.embedding.EmbeddingSearchRequest;\\nimport dev.langchain4j.store.embedding.EmbeddingSearchResult;\\nimport dev.langchain4j.store.embedding.EmbeddingStore;\\nimport org.slf4j.Logger;\\nimport org.slf4j.LoggerFactory;\\nimport org.springframework.stereotype.Service;\\nimport reactor.core.publisher.Flux;\\n\\nimport java.time.Duration;\\nimport java.time.Instant;\\nimport java.util.List;\\nimport java.util.stream.Collectors;\\n\\n@Service\\npublic class SmartHomeQueryService {\\n\\n    private static final Logger logger = LoggerFactory.getLogger(SmartHomeQueryService.class);\\n\\n    private final EmbeddingModel embeddingModel;\\n    private final EmbeddingStore<TextSegment> embeddingStore;\\n    private final OpenAiChatModel chatModel;\\n    private final SessionManagementService sessionManagementService;\\n\\n    // 系统提示模板\\n    private static final String SYSTEM_PROMPT = \\\"\\\"\\\"\\n    你是一个专业的智能家居知识库助手，精通各种智能家居设备的使用和故障排查。\\n    你的任务是基于提供的文档内容，为用户提供准确、专业的回答。\\n    \\n    注意事项：\\n    1. 只基于提供的文档内容回答，不要添加文档中没有的信息\\n    2. 回答要清晰、简洁，避免使用专业术语\\n    3. 对于故障排查问题，提供详细的步骤指导\\n    4. 如果无法从文档中找到答案，诚实地告诉用户\\n    5. 保持友好、专业的语气\\n    \\\"\\\"\\\";\\n\\n    // 少样本提示模板\\n    private static final String FEW_SHOT_PROMPT = \\\"\\\"\\\"\\n    示例 1：\\n    用户问题：我的空调不制冷了怎么办？\\n    文档内容：当空调不制冷时，首先检查电源是否正常，然后检查温度设置是否正确，最后检查过滤网是否清洁。\\n    回答：当您的空调不制冷时，建议您按照以下步骤排查：\\n    1. 检查空调电源是否正常连接\\n    2. 确认温度设置是否低于当前室内温度\\n    3. 检查空调过滤网是否需要清洁\\n    \\n    示例 2：\\n    用户问题：如何设置电视的睡眠定时器？\\n    文档内容：要设置电视的睡眠定时器，首先进入设置菜单，选择时间设置，然后选择睡眠定时器，设置您希望电视关闭的时间。\\n    回答：要设置电视的睡眠定时器，请按照以下步骤操作：\\n    1. 按下遥控器上的\\\"菜单\\\"按钮\\n    2. 导航到\\\"设置\\\"选项\\n    3. 选择\\\"时间设置\\\"\\n    4. 选择\\\"睡眠定时器\\\"\\n    5. 设置您希望电视自动关闭的时间\\n    \\\"\\\"\\\";\\n\\n    // RAG 提示模板\\n    private static final String RAG_PROMPT_TEMPLATE = \\\"\\\"\\\"\\n    %s\\n    \\n    %s\\n    \\n    文档内容：\\n    %s\\n    \\n    用户问题：%s\\n    设备类型：%s\\n    设备型号：%s\\n    \\n    请基于上述文档内容回答用户问题，保持回答简洁明了。\\n    \\\"\\\"\\\";\\n\\n    public SmartHomeQueryService(\\n            EmbeddingModel embeddingModel,\\n            EmbeddingStore<TextSegment> embeddingStore,\\n            OpenAiChatModel chatModel,\\n            SessionManagementService sessionManagementService) {\\n        this.embeddingModel = embeddingModel;\\n        this.embeddingStore = embeddingStore;\\n        this.chatModel = chatModel;\\n        this.sessionManagementService = sessionManagementService;\\n    }\\n\\n    /**\\n     * 处理智能家具查询\\n     */\\n    public SmartHomeQueryResponse query(SmartHomeQueryRequest request) {\\n        Instant start = Instant.now();\\n\\n        try {\\n            // 1. 向量化查询\\n            Embedding queryEmbedding = embeddingModel.embed(request.query()).content();\\n\\n            // 2. 搜索相关文档\\n            EmbeddingSearchRequest searchRequest = EmbeddingSearchRequest.builder()\\n                    .queryEmbedding(queryEmbedding)\\n                    .maxResults(3) // Top-3 召回\\n                    .build();\\n\\n            EmbeddingSearchResult<TextSegment> searchResult = embeddingStore.search(searchRequest);\\n            List<EmbeddingMatch<TextSegment>> matches = searchResult.matches();\\n\\n            // 3. 构建上下文\\n            String context = matches.stream()\\n                    .map(match -> match.embedded().text())\\n                    .collect(Collectors.joining(\\\"\\\\n\\\\n\\\"));\\n\\n            // 4. 构建提示\\n            String promptText = String.format(\\n                    RAG_PROMPT_TEMPLATE,\\n                    SYSTEM_PROMPT,\\n                    FEW_SHOT_PROMPT,\\n                    context,\\n                    request.query(),\\n                    request.deviceType() != null ? request.deviceType() : \\\"未知\\\",\\n                    request.deviceModel() != null ? request.deviceModel() : \\\"未知\\\"\\n            );\\n\\n            Prompt prompt = new Prompt(promptText);\\n\\n            // 5. 生成回答\\n            String answer = chatModel.generate(prompt.text());\\n\\n            // 6. 提取来源\\n            List<String> sources = matches.stream()\\n                    .map(match -> {\\n                        TextSegment segment = match.embedded();\\n                        return segment.metadata().getOrDefault(\\\"source\\\", \\\"未知\\\");\\n                    })\\n                    .collect(Collectors.toList());\\n\\n            // 7. 计算置信度（基于相似度分数）\\n            double confidence = matches.stream()\\n                    .mapToDouble(EmbeddingMatch::score)\\n                    .average()\\n                    .orElse(0.0);\\n\\n            // 8. 记录会话\\n            sessionManagementService.addMessage(request.query(), answer);\\n\\n            long responseTime = Duration.between(start, Instant.now()).toMillis();\\n\\n            return new SmartHomeQueryResponse(answer, sources, confidence, responseTime);\\n        } catch (Exception e) {\\n            logger.error(\\\"Error processing query: {}\\\", request.query(), e);\\n            long responseTime = Duration.between(start, Instant.now()).toMillis();\\n            return new SmartHomeQueryResponse(\\n                    \\\"抱歉，处理您的请求时出现错误，请稍后再试。\\\",\\n                    List.of(),\\n                    0.0,\\n                    responseTime\\n            );\\n        }\\n    }\\n\\n    /**\\n     * 流式处理智能家具查询\\n     */\\n    public SmartHomeStreamResponse streamQuery(SmartHomeQueryRequest request) {\\n        try {\\n            // 1. 向量化查询\\n            Embedding queryEmbedding = embeddingModel.embed(request.query()).content();\\n\\n            // 2. 搜索相关文档\\n            EmbeddingSearchRequest searchRequest = EmbeddingSearchRequest.builder()\\n                    .queryEmbedding(queryEmbedding)\\n                    .maxResults(3)\\n                    .build();\\n\\n            EmbeddingSearchResult<TextSegment> searchResult = embeddingStore.search(searchRequest);\\n            List<EmbeddingMatch<TextSegment>> matches = searchResult.matches();\\n\\n            // 3. 构建上下文\\n            String context = matches.stream()\\n                    .map(match -> match.embedded().text())\\n                    .collect(Collectors.joining(\\\"\\\\n\\\\n\\\"));\\n\\n            // 4. 构建提示\\n            String promptText = String.format(\\n                    RAG_PROMPT_TEMPLATE,\\n                    SYSTEM_PROMPT,\\n                    FEW_SHOT_PROMPT,\\n                    context,\\n                    request.query(),\\n                    request.deviceType() != null ? request.deviceType() : \\\"未知\\\",\\n                    request.deviceModel() != null ? request.deviceModel() : \\\"未知\\\"\\n            );\\n\\n            // 5. 流式生成回答\\n            Flux<String> stream = Flux.create(sink -> {\\n                chatModel.generateStreaming(promptText, \\n                        chunk -> sink.next(chunk),\\n                        error -> sink.error(error),\\n                        () -> sink.complete()\\n                );\\n            });\\n\\n            // 6. 记录会话（异步）\\n            stream.collectList().subscribe(parts -> {\\n                String answer = String.join(\\\"\\\", parts);\\n                sessionManagementService.addMessage(request.query(), answer);\\n            });\\n\\n            return new SmartHomeStreamResponse(stream);\\n        } catch (Exception e) {\\n            logger.error(\\\"Error processing stream query: {}\\\", request.query(), e);\\n            return new SmartHomeStreamResponse(Flux.just(\\\"抱歉，处理您的请求时出现错误，请稍后再试。\\\"));\\n        }\\n    }\\n}\\n\",\"originTextLength\":7568,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1774622150432},{\"originRange\":{\"start\":{\"line\":161,\"character\":0},\"end\":{\"line\":161,\"character\":54}},\"modifyRange\":{\"start\":{\"line\":161,\"character\":0},\"end\":{\"line\":161,\"character\":54}},\"action\":\"None\",\"isLine\":false,\"originText\":\"                    java.util.Collections.emptyList(),\",\"originAcceptText\":\"                    java.util.Collections.emptyList(),\",\"originTextLength\":54,\"aiScene\":\