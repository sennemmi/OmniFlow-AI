  "range-cache-file:///c%3A/Users/xyx/Desktop/ai-playground-main/smart-home-rag/src/main/java/com/example/smarthome/domain/request/SmartHomeQueryRequest.java": "[{\"originRange\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":8,\"character\":0}},\"modifyRange\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":8,\"character\":0}},\"action\":\"None\",\"isLine\":false,\"originText\":\"package com.example.smarthome.domain.request;\\\\n\\\\nimport jakarta.validation.constraints.NotBlank;\\\\n\\\\npublic record SmartHomeQueryRequest(\\\\n        @NotBlank(message = \\\\\\\"查询内容不能为空\\\\\\\") String query,\\\\n        String deviceType,\\\\n        String deviceModel\\\\n) {\\\\n}\\\\n\",\"originAcceptText\":\"package com.example.smarthome.domain.request;\\n\\nimport jakarta.validation.constraints.NotBlank;\\n\\npublic record SmartHomeQueryRequest(\\n        @NotBlank(message = \\\"查询内容不能为空\\\") String query,\\n        String deviceType,\\n        String deviceModel\\n) {\\n}\\n\",\"originTextLength\":247,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1774701279510}]",
  "range-cache-file:///c%3A/Users/xyx/Desktop/ai-playground-main/smart-home-rag/src/main/java/com/example/smarthome/SmartHomeRagApplication.java": "[{\"originRange\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":9,\"character\":0}},\"modifyRange\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":9,\"character\":0}},\"action\":\"None\",\"isLine\":false,\"originText\":\"package com.example.smarthome;\\\\n\\\\nimport org.springframework.boot.SpringApplication;\\\\nimport org.springframework.boot.autoconfigure.SpringBootApplication;\\\\n\\\\n@SpringBootApplication\\\\npublic class SmartHomeRagApplication {\\\\n\\\\n    public static void main(String[] args) {\\\\n        SpringApplication.run(SmartHomeRagApplication.class, args);\\\\n    }\\\\n\\\\n}\\\\n\",\"originAcceptText\":\"package com.example.smarthome;\\n\\nimport org.springframework.boot.SpringApplication;\\nimport org.springframework.boot.autoconfigure.SpringBootApplication;\\n\\n@SpringBootApplication\\npublic class SmartHomeRagApplication {\\n\\n    public static void main(String[] args) {\\n        SpringApplication.run(SmartHomeRagApplication.class, args);\\n    }\\n\\n}\\n\",\"originTextLength\":338,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1774701279512}]",
  "range-cache-file:///c%3A/Users/xyx/Desktop/ai-playground-main/smart-home-rag/src/main/java/com/example/smarthome/service/SessionManagementService.java": "[{\"originRange\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":111,\"character\":0}},\"modifyRange\":{\"start\":{\"line\":0,\"character\":0},\"end\":{\"line\":111,\"character\":0}},\"action\":\"None\",\"isLine\":false,\"originText\":\"package com.example.smarthome.service;\\\\n\\\\nimport org.slf4j.Logger;\\\\nimport org.slf4j.LoggerFactory;\\\\nimport org.springframework.data.redis.core.ReactiveRedisTemplate;\\\\nimport org.springframework.stereotype.Service;\\\\n\\\\nimport java.time.Duration;\\\\nimport java.util.LinkedList;\\\\nimport java.util.List;\\\\nimport java.util.concurrent.ConcurrentHashMap;\\\\nimport java.util.concurrent.ConcurrentMap;\\\\n\\\\n@Service\\\\npublic class SessionManagementService {\\\\n\\\\n    private static final Logger logger = LoggerFactory.getLogger(SessionManagementService.class);\\\\n\\\\n    private final ReactiveRedisTemplate<String, String> redisTemplate;\\\\n    private final ConcurrentMap<String, LinkedList<String>> sessionCache = new ConcurrentHashMap<>();\\\\n    private static final String SESSION_PREFIX = \\\\\\\"smart_home_session:\\\\\\\";\\\\n    private static final int MAX_MESSAGES_PER_SESSION = 20; // 每个会话最多保存20条消息\\\\n    private static final int TOKEN_LIMIT = 1800; // 限制Token使用量\\\\n\\\\n    public SessionManagementService(ReactiveRedisTemplate<String, String> redisTemplate) {\\\\n        this.redisTemplate = redisTemplate;\\\\n    }\\\\n\\\\n    /**\\\\n     * 添加消息到会话\\\\n     */\\\\n    public void addMessage(String userQuery, String aiResponse) {\\\\n        // 简化处理，使用默认会话ID\\\\n        String sessionId = \\\\\\\"default\\\\\\\";\\\\n        String sessionKey = SESSION_PREFIX + sessionId;\\\\n\\\\n        // 获取现有会话\\\\n        LinkedList<String> messages = sessionCache.computeIfAbsent(sessionId, k -> new LinkedList<>());\\\\n\\\\n        // 添加新消息\\\\n        messages.add(\\\\\\\"用户: \\\\\\\" + userQuery);\\\\n        messages.add(\\\\\\\"助手: \\\\\\\" + aiResponse);\\\\n\\\\n        // 裁剪消息，保持在限制范围内\\\\n        trimMessages(messages);\\\\n\\\\n        // 保存到Redis\\\\n        saveSessionToRedis(sessionKey, messages);\\\\n\\\\n        logger.info(\\\\\\\"Added message to session: {}\\\\\\\", sessionId);\\\\n    }\\\\n\\\\n    /**\\\\n     * 获取会话历史\\\\n     */\\\\n    public List<String> getSessionHistory() {\\\\n        String sessionId = \\\\\\\"default\\\\\\\";\\\\n        String sessionKey = SESSION_PREFIX + sessionId;\\\\n\\\\n        // 先从缓存获取\\\\n        LinkedList<String> messages = sessionCache.get(sessionId);\\\\n        if (messages != null) {\\\\n            return messages;\\\\n        }\\\\n\\\\n        // 从Redis获取\\\\n        // 注意：这里简化处理，实际项目中应该使用Redis的响应式API\\\\n        return new LinkedList<>();\\\\n    }\\\\n\\\\n    /**\\\\n     * 裁剪消息，保持在限制范围内\\\\n     */\\\\n    private void trimMessages(LinkedList<String> messages) {\\\\n        // 限制消息数量\\\\n        while (messages.size() > MAX_MESSAGES_PER_SESSION) {\\\\n            messages.removeFirst();\\\\n        }\\\\n\\\\n        // 限制Token使用量\\\\n        int totalTokens = 0;\\\\n        LinkedList<String> trimmedMessages = new LinkedList<>();\\\\n\\\\n        // 从最新消息开始，计算Token数\\\\n        for (int i = messages.size() - 1; i >= 0; i--) {\\\\n            String message = messages.get(i);\\\\n            int messageTokens = estimateTokens(message);\\\\n\\\\n            if (totalTokens + messageTokens <= TOKEN_LIMIT) {\\\\n                trimmedMessages.addFirst(message);\\\\n                totalTokens += messageTokens;\\\\n            } else {\\\\n                break;\\\\n            }\\\\n        }\\\\n\\\\n        // 替换为裁剪后的消息\\\\n        if (!trimmedMessages.isEmpty()) {\\\\n            messages.clear();\\\\n            messages.addAll(trimmedMessages);\\\\n        }\\\\n\\\\n        logger.info(\\\\\\\"Trimmed session messages to {} tokens\\\\\\\", totalTokens);\\\\n    }\\\\n\\\\n    /**\\\\n     * 估算消息的Token数\\\\n     */\\\\n    private int estimateTokens(String text) {\\\\n        // 简单估算：1个Token约等于4个字符\\\\n        return (text.length() + 3) / 4;\\\\n    }\\\\n\\\\n    /**\\\\n     * 保存会话到Redis\\\\n     */\\\\n    private void saveSessionToRedis(String sessionKey, List<String> messages) {\\\\n        // 简化处理，实际项目中应该使用Redis的响应式API\\\\n        // 这里只是示例，实际实现需要使用redisTemplate\\\\n        logger.info(\\\\\\\"Saving session to Redis: {}\\\\\\\", sessionKey);\\\\n    }\\\\n\\\\n    /**\\\\n     * 清除会话\\\\n     */\\\\n    public void clearSession() {\\\\n        String sessionId = \\\\\\\"default\\\\\\\";\\\\n        String sessionKey = SESSION_PREFIX + sessionId;\\\\n\\\\n        // 清除缓存\\\\n        sessionCache.remove(sessionId);\\\\n\\\\n        // 清除Redis\\\\n        // 实际项目中应该使用redisTemplate.delete(sessionKey)\\\\n        logger.info(\\\\\\\"Cleared session: {}\\\\\\\", sessionId);\\\\n    }\\\\n}\\\\n\",\"originAcceptText\":\"package com.example.smarthome.service;\\n\\nimport org.slf4j.Logger;\\nimport org.slf4j.LoggerFactory;\\nimport org.springframework.data.redis.core.ReactiveRedisTemplate;\\nimport org.springframework.stereotype.Service;\\n\\nimport java.time.Duration;\\nimport java.util.LinkedList;\\nimport java.util.List;\\nimport java.util.concurrent.ConcurrentHashMap;\\nimport java.util.concurrent.ConcurrentMap;\\n\\n@Service\\npublic class SessionManagementService {\\n\\n    private static final Logger logger = LoggerFactory.getLogger(SessionManagementService.class);\\n\\n    private final ReactiveRedisTemplate<String, String> redisTemplate;\\n    private final ConcurrentMap<String, LinkedList<String>> sessionCache = new ConcurrentHashMap<>();\\n    private static final String SESSION_PREFIX = \\\"smart_home_session:\\\";\\n    private static final int MAX_MESSAGES_PER_SESSION = 20; // 每个会话最多保存20条消息\\n    private static final int TOKEN_LIMIT = 1800; // 限制Token使用量\\n\\n    public SessionManagementService(ReactiveRedisTemplate<String, String> redisTemplate) {\\n        this.redisTemplate = redisTemplate;\\n    }\\n\\n    /**\\n     * 添加消息到会话\\n     */\\n    public void addMessage(String userQuery, String aiResponse) {\\n        // 简化处理，使用默认会话ID\\n        String sessionId = \\\"default\\\";\\n        String sessionKey = SESSION_PREFIX + sessionId;\\n\\n        // 获取现有会话\\n        LinkedList<String> messages = sessionCache.computeIfAbsent(sessionId, k -> new LinkedList<>());\\n\\n        // 添加新消息\\n        messages.add(\\\"用户: \\\" + userQuery);\\n        messages.add(\\\"助手: \\\" + aiResponse);\\n\\n        // 裁剪消息，保持在限制范围内\\n        trimMessages(messages);\\n\\n        // 保存到Redis\\n        saveSessionToRedis(sessionKey, messages);\\n\\n        logger.info(\\\"Added message to session: {}\\\", sessionId);\\n    }\\n\\n    /**\\n     * 获取会话历史\\n     */\\n    public List<String> getSessionHistory() {\\n        String sessionId = \\\"default\\\";\\n        String sessionKey = SESSION_PREFIX + sessionId;\\n\\n        // 先从缓存获取\\n        LinkedList<String> messages = sessionCache.get(sessionId);\\n        if (messages != null) {\\n            return messages;\\n        }\\n\\n        // 从Redis获取\\n        // 注意：这里简化处理，实际项目中应该使用Redis的响应式API\\n        return new LinkedList<>();\\n    }\\n\\n    /**\\n     * 裁剪消息，保持在限制范围内\\n     */\\n    private void trimMessages(LinkedList<String> messages) {\\n        // 限制消息数量\\n        while (messages.size() > MAX_MESSAGES_PER_SESSION) {\\n            messages.removeFirst();\\n        }\\n\\n        // 限制Token使用量\\n        int totalTokens = 0;\\n        LinkedList<String> trimmedMessages = new LinkedList<>();\\n\\n        // 从最新消息开始，计算Token数\\n        for (int i = messages.size() - 1; i >= 0; i--) {\\n            String message = messages.get(i);\\n            int messageTokens = estimateTokens(message);\\n\\n            if (totalTokens + messageTokens <= TOKEN_LIMIT) {\\n                trimmedMessages.addFirst(message);\\n                totalTokens += messageTokens;\\n            } else {\\n                break;\\n            }\\n        }\\n\\n        // 替换为裁剪后的消息\\n        if (!trimmedMessages.isEmpty()) {\\n            messages.clear();\\n            messages.addAll(trimmedMessages);\\n        }\\n\\n        logger.info(\\\"Trimmed session messages to {} tokens\\\", totalTokens);\\n    }\\n\\n    /**\\n     * 估算消息的Token数\\n     */\\n    private int estimateTokens(String text) {\\n        // 简单估算：1个Token约等于4个字符\\n        return (text.length() + 3) / 4;\\n    }\\n\\n    /**\\n     * 保存会话到Redis\\n     */\\n    private void saveSessionToRedis(String sessionKey, List<String> messages) {\\n        // 简化处理，实际项目中应该使用Redis的响应式API\\n        // 这里只是示例，实际实现需要使用redisTemplate\\n        logger.info(\\\"Saving session to Redis: {}\\\", sessionKey);\\n    }\\n\\n    /**\\n     * 清除会话\\n     */\\n    public void clearSession() {\\n        String sessionId = \\\"default\\\";\\n        String sessionKey = SESSION_PREFIX + sessionId;\\n\\n        // 清除缓存\\n        sessionCache.remove(sessionId);\\n\\n        // 清除Redis\\n        // 实际项目中应该使用redisTemplate.delete(sessionKey)\\n        logger.info(\\\"Cleared session: {}\\\", sessionId);\\n    }\\n}\\n\",\"originTextLength\":3894,\"aiScene\":\"builder\",\"behaviorType\":\"accept\",\"updateTime\":1774701279515}]",
